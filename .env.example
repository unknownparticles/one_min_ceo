# Local development only. GitHub Pages uses the SILICONFLOW_API_KEY repository
# secret and writes public/runtime-config.js during GitHub Actions build.
VITE_SILICONFLOW_API_KEY="MY_SILICONFLOW_API_KEY"
VITE_SILICONFLOW_MODEL="Qwen/Qwen2.5-14B-Instruct"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
