  "npcs": [
    {
      "id": "npc1",
      "name": "火星矿工代表",
      "dialogue": "我们被欠薪三个月了！",
      "storyline": [
        {
          "stage": 1,
          "text": "矿工代表愤怒地指责你拖欠工资。",
          "options": [
            {
              "text": "安抚并承诺发薪",
              "nextStage": 2
            },
            {
              "text": "威胁开除",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "矿工暂时平静，但要求立即支付。",
          "options": [
            {
              "text": "开支票",
              "nextStage": "ending1"
            },
            {
              "text": "拖延时间",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "矿工们开始暴动。",
          "options": [
            {
              "text": "叫保安",
              "nextStage": "ending2"
            },
            {
              "text": "逃往避难所",
              "nextStage": "ending3"
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "董事会秘书",
      "dialogue": "股东们要求紧急会议！",
      "storyline": [
        {
          "stage": 1,
          "text": "秘书惊慌失措地通知你股东要求立即开会。",
          "options": [
            {
              "text": "参加电话会议",
              "nextStage": 2
            },
            {
              "text": "拒绝并关机",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "股东们质询财务造假。",
          "options": [
            {
              "text": "承认并辞职",
              "nextStage": "ending4"
            },
            {
              "text": "狡辩并推卸责任",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "股东会通过罢免提案。",
          "options": [
            {
              "text": "强行解散会议",
              "nextStage": "ending5"
            },
            {
              "text": "接受罢免",
              "nextStage": "ending6"
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "财务总监",
      "dialogue": "账目漏洞已无法掩盖！",
      "storyline": [
        {
          "stage": 1,
          "text": "财务总监告诉你审计发现巨大黑洞。",
          "options": [
            {
              "text": "销毁证据",
              "nextStage": 2
            },
            {
              "text": "坦白自首",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "你试图销毁文件，但被监控拍下。",
          "options": [
            {
              "text": "贿赂保安",
              "nextStage": "ending7"
            },
            {
              "text": "自首",
              "nextStage": "ending8"
            }
          ]
        },
        {
          "stage": 3,
          "text": "你决定自首，但律师劝阻。",
          "options": [
            {
              "text": "坚持自首",
              "nextStage": "ending9"
            },
            {
              "text": "听律师的",
              "nextStage": 2
            }
          ]
        }
      ]
    },
    {
      "id": "npc4",
      "name": "火星总督",
      "dialogue": "你的采矿许可证将被吊销！",
      "storyline": [
        {
          "stage": 1,
          "text": "总督通知你因环境破坏将被吊销执照。",
          "options": [
            {
              "text": "行贿总督",
              "nextStage": 2
            },
            {
              "text": "公开道歉并承诺整改",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "总督接受了贿赂，但被记者拍到。",
          "options": [
            {
              "text": "威胁记者",
              "nextStage": "ending10"
            },
            {
              "text": "逃跑",
              "nextStage": "ending11"
            }
          ]
        },
        {
          "stage": 3,
          "text": "道歉后公众并不买账。",
          "options": [
            {
              "text": "加大环保投入",
              "nextStage": "ending12"
            },
            {
              "text": "破产清算",
              "nextStage": "ending13"
            }
          ]
        }
      ]
    },
    {
      "id": "npc5",
      "name": "竞争对手CEO",
      "dialogue": "我们来收购你的公司。",
      "storyline": [
        {
          "stage": 1,
          "text": "对手提出低价收购。",
          "options": [
            {
              "text": "同意收购",
              "nextStage": 2
            },
            {
              "text": "拒绝并嘲讽",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "收购条款极其苛刻。",
          "options": [
            {
              "text": "接受条款",
              "nextStage": "ending14"
            },
            {
              "text": "反悔",
              "nextStage": "ending15"
            }
          ]
        },
        {
          "stage": 3,
          "text": "你拒绝了收购，对手开始恶意做空。",
          "options": [
            {
              "text": "反击做空",
              "nextStage": "ending16"
            },
            {
              "text": "寻求政府救助",
              "nextStage": "ending17"
            }
          ]
        }
      ]
    }
  ],
