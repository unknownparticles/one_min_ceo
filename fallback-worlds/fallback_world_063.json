  "npcs": [
    {
      "id": "npc1",
      "name": "量子先知",
      "x": 3,
      "y": 3,
      "dialogue": "神殿即将开启，你准备好了吗？",
      "storyline": [
        {
          "stage": 0,
          "text": "先知站在水晶旁，眼神深邃。",
          "options": [
            {
              "text": "询问神殿的秘密",
              "nextStage": 1
            },
            {
              "text": "无视他",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "text": "先知低语：神殿深处藏着量子之核，但需要三个碎片。",
          "options": [
            {
              "text": "我愿意寻找碎片",
              "nextStage": 3
            },
            {
              "text": "太危险了",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 2,
          "text": "先知叹息：时间不多了。",
          "options": [
            {
              "text": "回头",
              "nextStage": 0
            }
          ]
        },
        {
          "stage": 3,
          "text": "先知点头：很好，碎片分别由其他守护者持有。",
          "options": [
            {
              "text": "去找其他守护者",
              "nextStage": 0
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "守护者阿卡",
      "x": 8,
      "y": 3,
      "dialogue": "我是火焰的守护者。",
      "storyline": [
        {
          "stage": 0,
          "text": "阿卡周身环绕火焰。",
          "options": [
            {
              "text": "挑战他",
              "nextStage": 1
            },
            {
              "text": "礼貌询问碎片",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "text": "阿卡大笑：打败我才能得到碎片！",
          "options": [
            {
              "text": "接受挑战",
              "nextStage": 3
            },
            {
              "text": "放弃",
              "nextStage": 0
            }
          ]
        },
        {
          "stage": 2,
          "text": "阿卡：碎片可以给你，但你得证明你的价值。",
          "options": [
            {
              "text": "展示力量",
              "nextStage": 3
            },
            {
              "text": "展示智慧",
              "nextStage": 4
            }
          ]
        },
        {
          "stage": 3,
          "text": "阿卡赞赏：你通过了！给你碎片。",
          "options": [
            {
              "text": "接过碎片",
              "nextStage": 0
            }
          ]
        },
        {
          "stage": 4,
          "text": "阿卡疑惑：这还不够。",
          "options": [
            {
              "text": "再次尝试",
              "nextStage": 2
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "守护者冰霜",
      "x": 2,
      "y": 7,
      "dialogue": "寒冷就是我的力量。",
      "storyline": [
        {
          "stage": 0,
          "text": "冰霜雕像般矗立。",
          "options": [
            {
              "text": "融化他的冰心",
              "nextStage": 1
            },
            {
              "text": "直接索要碎片",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "text": "冰霜微微动容：你的热情让我动摇。",
          "options": [
            {
              "text": "继续温暖他",
              "nextStage": 3
            },
            {
              "text": "趁机抢夺",
              "nextStage": 4
            }
          ]
        },
        {
          "stage": 2,
          "text": "冰霜冷笑：你以为你是谁？",
          "options": [
            {
              "text": "道歉",
              "nextStage": 0
            },
            {
              "text": "威胁",
              "nextStage": 4
            }
          ]
        },
        {
          "stage": 3,
          "text": "冰霜融化，交出碎片。",
          "options": [
            {
              "text": "接过碎片",
              "nextStage": 0
            }
          ]
        },
        {
          "stage": 4,
          "text": "冰霜暴怒，战斗开始！",
          "options": [
            {
              "text": "逃跑",
              "nextStage": 0
            },
            {
              "text": "战斗",
              "nextStage": 3
            }
          ]
        }
      ]
    },
    {
      "id": "npc4",
