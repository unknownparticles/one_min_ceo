        {
          "stage": 1,
          "text": "王冷笑道：我已经冻结了所有资产，你们完了。",
          "options": [
            {
              "text": "强行关闭控制台",
              "nextStage": 3,
              "effect": {
                "variable": "shutdown",
                "value": 1
              }
            },
            {
              "text": "呼叫保安",
              "nextStage": 4,
              "effect": {
                "variable": "call_guard",
                "value": 1
              }
            }
          ]
        },
        {
          "stage": 2,
          "text": "王满意地点头：识时务者为俊杰。你去解决CEO。",
          "options": [
            {
              "text": "答应但拖延",
              "nextStage": 5,
              "effect": {
                "variable": "delay",
                "value": 1
              }
            },
            {
              "text": "假意答应，实则通知CEO",
              "nextStage": 6,
              "effect": {
                "variable": "warn_ceo",
                "value": 1
              }
            }
          ]
        }
      ]
    },
