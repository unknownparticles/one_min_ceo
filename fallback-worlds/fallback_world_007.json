        {
          "stage": 1,
          "text": "陈低声说：财务总监联合了技术主管，他们要在60秒后发动攻击。",
          "options": [
            {
              "text": "去阻止财务总监",
              "nextStage": 3,
              "effect": {
                "variable": "block_finance",
                "value": 1
              }
            },
            {
              "text": "去说服技术主管",
              "nextStage": 4,
              "effect": {
                "variable": "convince_tech",
                "value": 1
              }
