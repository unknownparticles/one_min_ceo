          ]
        },
        {
          "stage": 2,
          "text": "陈露出欣慰的笑容：好！我们反击！",
          "options": [
            {
              "text": "召集保安",
              "nextStage": 5,
              "effect": {
                "variable": "security",
                "value": 1
              }
            },
            {
              "text": "准备撤离",
              "nextStage": 6,
              "effect": {
                "variable": "escape",
                "value": 1
              }
            }
          ]
        }
      ]
    },
    {
      "id": "npc_finance",
      "name": "财务总监_王",
      "dialogue": [
        "哼，你发现了？",
        "董事会已经腐朽，必须清洗！",
        "要么加入我，要么消失。"
      ],
      "position": {
        "x": 5,
        "y": 5
      },
      "storyline": [
        {
          "stage": 0,
          "text": "财务总监_王正对着全息屏幕操作着什么。",
          "options": [
            {
              "text": "质问他的计划",
              "nextStage": 1,
              "effect": {
                "variable": "confront_finance",
                "value": 1
              }
            },
            {
              "text": "假意合作",
              "nextStage": 2,
              "effect": {
                "variable": "pretend",
                "value": 1
              }
            }
