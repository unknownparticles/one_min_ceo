  "npcs": [
    {
      "id": "npc1",
      "name": "数据占卜师",
      "description": "一个全身由流动数据构成的预言者，眼睛闪烁着红色代码。",
      "position": [
        3,
        4
      ],
      "storyline": [
        {
          "stage": 1,
          "dialogue": "啊，你来了。我看到了你的命运——赛博财神将在60秒后降临，但你的财富指数正在下跌。",
          "options": [
            {
              "text": "请告诉我如何提升财富指数？",
              "nextStage": 2
            },
            {
              "text": "我不信命运，我自己会赚钱。",
              "nextStage": 1
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "你需要收集三个金元宝，并避开负面情绪陷阱。时间不多了。",
          "options": [
            {
              "text": "金元宝在哪里？",
              "nextStage": 3
            },
            {
              "text": "负面情绪陷阱是什么？",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "金元宝在宝库中，但宝库需要密码。密码是'666'。快去吧！",
          "options": [
            {
              "text": "谢谢，我这就去。",
              "nextStage": 3
            },
            {
              "text": "等等，你还没说陷阱。",
              "nextStage": 3
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "情绪黑客",
