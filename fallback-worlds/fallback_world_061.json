      "storyline": [
        {
          "stage": 1,
          "dialogue": "哈！你看起来压力很大。我可以帮你调节情绪，但需要收费。",
          "options": [
            {
              "text": "收费多少？",
              "nextStage": 2
            },
            {
              "text": "我不需要，我自己能调节。",
              "nextStage": 1
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "不贵，只需一个金元宝。我可以让你保持积极状态，提升财富指数。",
          "options": [
            {
              "text": "成交！",
              "nextStage": 3
            },
            {
              "text": "太贵了，我拒绝。",
              "nextStage": 1
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "交易完成！你现在获得了'乐观光环'，接下来30秒内财富指数提升20%。",
          "options": [
            {
              "text": "太好了！",
              "nextStage": 3
            },
            {
              "text": "感觉不错。",
              "nextStage": 3
