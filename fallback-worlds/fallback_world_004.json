              "text": "命令保安封锁大门",
              "action": "lock"
            },
            {
              "text": "打开金库展示储备",
              "action": "show_vault"
            }
          ]
        },
        {
          "stage": 3,
          "text": "柜员指向窗外：'看！他们开始撞门了！'",
          "options": [
            {
              "text": "启动应急广播",
              "action": "broadcast"
            },
            {
              "text": "从后门逃跑",
              "action": "escape"
            }
          ]
        }
      ]
    },
    {
      "id": "quantum_security",
      "name": "量子保安",
      "position": [
