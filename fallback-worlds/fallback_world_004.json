      "dialogue": "我是量子央行特派员。",
      "storyline": [
        {
          "stage": 1,
          "text": "神秘人出示证件：'我是来调查挤兑事件的。'",
          "options": [
            {
              "text": "配合调查",
              "action": "cooperate"
