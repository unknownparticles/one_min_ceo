        {
          "stage": 3,
          "text": "保安倒下：'量子辐射...太多了...'",
          "options": [
            {
              "text": "呼叫医疗兵",
              "action": "medic"
            },
            {
              "text": "继续处理危机",
              "action": "proceed"
            }
          ]
        }
      ]
    },
