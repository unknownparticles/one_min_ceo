      "id": "quantum_teller",
      "name": "量子柜员",
      "position": [
        2,
        3
      ],
      "dialogue": "董事长！存款量子态崩溃了！",
      "storyline": [
        {
          "stage": 1,
          "text": "量子柜员惊慌失措地喊道：'存款量子态正在坍缩！'",
          "options": [
            {
              "text": "启动量子稳定器",
              "action": "stabilize"
            },
            {
              "text": "安抚柜员",
              "action": "calm"
            }
          ]
