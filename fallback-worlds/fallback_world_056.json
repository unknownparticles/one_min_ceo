            },
            {
              "text": "报告安全部门",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "他坚持说看到了。",
          "options": [
            {
              "text": "跟随他",
              "nextStage": 6
            },
            {
              "text": "无视",
              "nextStage": 7
            }
