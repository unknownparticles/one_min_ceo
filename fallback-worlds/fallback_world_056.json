  "npcs": [
    {
      "id": "npc1",
      "name": "保安张",
      "dialogue": "主任，泄漏警报响了！",
      "position": [
        1,
        3
      ],
      "storyline": [
        {
          "stage": 1,
          "text": "保安张慌张地跑过来。",
          "options": [
            {
              "text": "问详情",
              "nextStage": 2
            },
            {
              "text": "叫他冷静",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "他说：泄漏源在服务器室。",
          "options": [
            {
              "text": "去服务器室",
              "nextStage": 4
            },
            {
              "text": "启动紧急程序",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "他深呼吸，报告说只是小泄漏。",
          "options": [
            {
              "text": "相信他",
              "nextStage": 6
            },
            {
              "text": "亲自检查",
              "nextStage": 7
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "科学家李",
      "position": [
        5,
        5
      ],
      "dialogue": "我找到了中和剂！",
      "storyline": [
        {
          "stage": 1,
          "text": "李博士举着一瓶绿色液体。",
          "options": [
            {
              "text": "拿过来",
              "nextStage": 2
            },
            {
              "text": "怀疑其效果",
              "nextStage": 3
            }
          ]
