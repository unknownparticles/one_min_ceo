        },
        {
          "stage": 3,
          "text": "他解释说这是新研发的。",
          "options": [
            {
              "text": "相信他",
              "nextStage": 6
            },
            {
              "text": "丢弃它",
              "nextStage": 7
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "实习生小王",
      "position": [
        3,
        8
      ],
      "dialogue": "我好像按错了按钮...",
      "storyline": [
        {
          "stage": 1,
          "text": "小王脸色苍白。",
          "options": [
            {
              "text": "问他按了什么",
              "nextStage": 2
            },
            {
              "text": "安慰他",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "他说启动了自毁程序。",
          "options": [
            {
              "text": "取消自毁",
              "nextStage": 4
