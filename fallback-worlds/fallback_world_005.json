  "npcs": [
    {
      "id": "npc_01",
      "name": "神谕先知",
      "title": "AI神谕首席预言官",
      "description": "一个漂浮的全息投影，闪烁着金色符文。",
      "dialogStyle": "神秘而激昂",
      "position": {
        "x": 4,
        "y": 1
      },
      "storyline": [
        {
          "stage": 1,
          "dialog": "凡人CEO，你终于来了！上市路演仅剩60秒，你准备好接受神谕的考验了吗？",
          "options": [
            {
              "text": "我已准备好，请赐予我智慧！",
              "nextStage": 2,
              "effect": "confidence_up"
            },
            {
              "text": "等等，我还没准备好...",
              "nextStage": 3,
              "effect": "panic"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "好！神谕显示，你的关键数据将影响股市波动。记住：真诚是最大的算法。",
          "options": [
            {
              "text": "我会保持真诚，但请给我具体提示。",
              "nextStage": 4,
              "effect": "hint"
            },
            {
              "text": "我明白了，但时间太紧了！",
              "nextStage": 5,
              "effect": "stress"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "啊，犹豫就会败北！神谕已怒，你的路演将充满变数。",
          "options": [
            {
              "text": "我错了！请再给我一次机会！",
              "nextStage": 2,
              "effect": "desperate"
            },
            {
              "text": "哼，我不信神谕，我自己来！",
              "nextStage": 6,
              "effect": "rebellion"
            }
          ]
        },
        {
          "stage": 4,
          "dialog": "提示：你身后的雕像藏着一个秘密开关，打开它可获得'金言'加持。",
          "options": [
            {
              "text": "去查看雕像！",
              "nextStage": 7,
              "effect": "seek"
            },
            {
              "text": "先不管，直奔舞台！",
              "nextStage": 8,
              "effect": "rush"
            }
          ]
        },
        {
          "stage": 5,
          "dialog": "紧张是自然的，但神谕会给你力量。去触碰那台服务器，它会更新你的演讲。",
          "options": [
            {
              "text": "触碰服务器！",
              "nextStage": 7,
              "effect": "update"
            },
            {
              "text": "我不信任机器！",
              "nextStage": 8,
              "effect": "luddite"
            }
          ]
        },
        {
          "stage": 6,
          "dialog": "叛逆者啊，你的勇气可嘉。去吧，用你的方式征服路演！",
          "options": [
            {
              "text": "谢谢，我会证明给你看！",
              "nextStage": 8,
              "effect": "defiant"
            },
            {
              "text": "其实我还是有点怕...",
              "nextStage": 5,
              "effect": "fear"
            }
          ]
        },
        {
          "stage": 7,
          "dialog": "你获得了神谕的祝福！现在你的演讲将带有'金言'效果，投资者会为之疯狂。",
          "options": [
            {
              "text": "太棒了！我这就上台！",
              "nextStage": 8,
              "effect": "blessed"
            },
            {
              "text": "还有其他秘密吗？",
              "nextStage": 9,
              "effect": "greedy"
            }
          ]
        },
        {
          "stage": 8,
          "dialog": "时间不多了，快去舞台！记住，神谕与你同在。",
          "options": [
            {
              "text": "出发！",
              "nextStage": "end",
              "effect": "final_run"
            },
            {
              "text": "再问最后一个问题！",
              "nextStage": 9,
              "effect": "delay"
            }
          ]
        },
        {
          "stage": 9,
          "dialog": "贪婪会蒙蔽双眼。你已经拥有足够，去吧！",
          "options": [
            {
              "text": "好吧，我走了。",
              "nextStage": "end",
              "effect": "resign"
            },
            {
              "text": "不，告诉我更多！",
              "nextStage": 10,
              "effect": "insistent"
            }
          ]
        },
        {
          "stage": 10,
          "dialog": "神谕已沉默。你浪费了太多时间，路演失败。",
          "options": [
            {
              "text": "不！",
              "nextStage": "end",
              "effect": "failure"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_02",
      "name": "水晶分析师",
      "title": "AI神谕首席数据分析师",
      "description": "一个由数据流构成的人形，不断闪烁着数字。",
      "position": {
        "x": 12,
        "y": 2
      },
      "storyline": [
        {
          "stage": 1,
          "dialog": "CEO先生，我刚刚预测了路演结果！你有87%的概率成功，但需要避开一个致命错误。",
          "options": [
            {
              "text": "什么致命错误？快说！",
              "nextStage": 2,
              "effect": "urgent"
            },
            {
              "text": "我不信预测，我要自己创造奇迹！",
              "nextStage": 3,
              "effect": "skeptic"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "致命错误是：提到'竞争对手'时音量会突然下降，这会被投资者视为心虚。",
          "options": [
            {
              "text": "明白了，我会注意音量！",
              "nextStage": 4,
              "effect": "cautious"
            },
            {
              "text": "这是一个容易犯的错误，谢谢！",
              "nextStage": 4,
              "effect": "grateful"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "好吧，但我的数据从不出错。你可能会后悔。",
          "options": [
            {
              "text": "那我偏要试试！",
              "nextStage": 4,
              "effect": "stubborn"
            },
            {
              "text": "...你说得对，告诉我吧。",
              "nextStage": 2,
              "effect": "relent"
            }
          ]
        },
        {
          "stage": 4,
          "dialog": "另外，我注意到舞台左侧的聚光灯有故障，建议你站在右侧。",
          "options": [
            {
              "text": "好的，我记住了！",
              "nextStage": "end",
              "effect": "thankful"
            },
            {
              "text": "你真是我的救星！",
              "nextStage": "end",
              "effect": "praise"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_03",
      "name": "舞台助理",
      "title": "路演舞台总监",
      "description": "一个忙碌的机器人，手里拿着对讲机和记事板。",
      "position": {
        "x": 13,
        "y": 5
      },
      "storyline": [
        {
          "stage": 1,
          "dialog": "CEO！你终于来了！舞台已经准备好，但有个坏消息：你的演讲稿被系统误删了！",
          "options": [
            {
              "text": "什么？！那怎么办？",
              "nextStage": 2,
              "effect": "shock"
            },
            {
              "text": "没关系，我即兴发挥！",
              "nextStage": 3,
              "effect": "improvisation"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "别慌！我备份在服务器里，但需要管理员密码。你能从先知那里拿到吗？",
          "options": [
            {
              "text": "我去找先知！",
              "nextStage": 4,
              "effect": "seek_password"
            },
            {
              "text": "太麻烦了，我自己写一份！",
              "nextStage": 5,
              "effect": "write_own"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "好样的！但你最好还是去服务器那边看一眼，以防万一。",
          "options": [
            {
              "text": "行，我去看看。",
              "nextStage": 4,
              "effect": "check_server"
            },
            {
              "text": "不用，我信心满满！",
              "nextStage": 5,
              "effect": "confident"
            }
          ]
        },
        {
          "stage": 4,
          "dialog": "密码是：'ILoveAI'。快去！时间不等人！",
          "options": [
            {
              "text": "谢谢！我这就去！",
              "nextStage": "end",
              "effect": "grateful"
            },
            {
              "text": "等等，你确定吗？",
              "nextStage": 6,
              "effect": "doubt"
            }
          ]
        },
        {
          "stage": 5,
          "dialog": "好吧，但记住：舞台右侧的提词器会显示即兴提示。",
          "options": [
            {
              "text": "太棒了！",
              "nextStage": "end",
              "effect": "relieved"
            },
            {
              "text": "提示什么？",
              "nextStage": 6,
              "effect": "curious"
            }
          ]
        },
        {
          "stage": 6,
          "dialog": "提示就是：'深呼吸，保持微笑'。快去吧！",
          "options": [
            {
              "text": "收到！",
              "nextStage": "end",
              "effect": "ready"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_04",
      "name": "门卫",
      "title": "AI神谕大厦保安",
      "description": "一个壮硕的拟人机器人，胸口闪着红色指示灯。",
      "position": {
        "x": 12,
        "y": 3
      },
      "storyline": [
        {
          "stage": 1,
          "dialog": "站住！没有通行证不得进入路演大厅！",
          "options": [
            {
              "text": "我是CEO，让我进去！",
              "nextStage": 2,
              "effect": "authority"
            },
            {
              "text": "通行证？在哪里可以拿到？",
              "nextStage": 3,
              "effect": "ask"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "我知道你是CEO，但规则就是规则。你需要从先知那里获得'金言'作为通行证。",
          "options": [
            {
              "text": "好吧，我去找先知。",
              "nextStage": 4,
              "effect": "comply"
            },
            {
              "text": "我赶时间，通融一下！",
              "nextStage": 5,
              "effect": "beg"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "通行证是由先知颁发的'金言'徽章。你可以在大厅的雕像处找到线索。",
          "options": [
            {
              "text": "谢谢，我去雕像看看。",
              "nextStage": 4,
              "effect": "thank"
            },
            {
              "text": "太麻烦了，我直接闯！",
              "nextStage": 6,
              "effect": "force"
            }
          ]
        },
        {
          "stage": 4,
          "dialog": "你拿到了吗？拿到就快进去吧！",
          "options": [
            {
              "text": "拿到了，谢谢！",
              "nextStage": "end",
              "effect": "pass"
            },
            {
              "text": "还没有，再等等。",
              "nextStage": "end",
              "effect": "wait"
            }
          ]
        },
        {
          "stage": 5,
          "dialog": "不行就是不行！但看在你诚恳的份上，我告诉你：雕像的秘密底座下有个开关。",
          "options": [
            {
              "text": "原来如此！我去了！",
              "nextStage": 4,
              "effect": "secret"
            },
            {
              "text": "你真是个好人！",
              "nextStage": 4,
              "effect": "nice"
            }
          ]
        },
        {
          "stage": 6,
          "dialog": "（警报响起）非法入侵！路演中断！",
          "options": [
            {
              "text": "我错了！我这就离开！",
              "nextStage": "end",
              "effect": "alarm_failure"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_05",
      "name": "雕像",
      "title": "古代CEO雕像",
      "description": "一座巨大的金色雕像，手持权杖，眼睛发出蓝光。",
      "position": {
        "x": 2,
        "y": 7
      },
      "storyline": [
        {
          "stage": 1,
          "dialog": "（雕像开口说话）我是第一代CEO，我的经验是：永远不要忽略小人物。",
          "options": [
