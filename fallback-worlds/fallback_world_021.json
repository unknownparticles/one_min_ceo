      "name": "神秘包裹",
      "description": "上面写着‘机密’，来自未知发件人。",
      "storyline": [
        {
          "stage": 1,
          "text": "包裹出现在桌上。",
          "options": [
            {
              "text": "打开它",
              "nextStage": 2,
              "effect": "open"
            },
            {
              "text": "扔掉",
