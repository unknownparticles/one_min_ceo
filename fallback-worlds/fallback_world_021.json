          "stage": 3,
          "text": "灯光太刺眼，观众看不清你。",
          "options": [
            {
              "text": "大声演讲",
              "nextStage": 4,
              "effect": "shout"
            },
            {
              "text": "走到台下",
              "nextStage": 4,
              "effect": "down"
            }
          ]
        },
        {
          "stage": 4,
          "text": "台下更混乱。",
          "options": [
            {
              "text": "维持秩序",
              "nextStage": 5,
              "effect": "order"
            },
            {
              "text": "逃离现场",
              "nextStage": 5,
              "effect": "flee"
            }
          ]
        },
        {
          "stage": 5,
          "text": "直播变成闹剧。",
          "options": []
        }
      ]
    },
    {
