              "effect": "pick"
            },
            {
              "text": "不去管它",
              "nextStage": 3,
              "effect": "ignore"
            }
          ]
        },
        {
          "stage": 3,
          "text": "硬币在直播中反射光，干扰摄像机。",
          "options": [
            {
              "text": "放进口袋",
              "nextStage": 4,
              "effect": "pocket"
            },
            {
              "text": "交给助手",
              "nextStage": 4,
              "effect": "assistant"
            }
          ]
        },
        {
          "stage": 4,
          "text": "助手不小心弄丢了。",
          "options": [
            {
              "text": "责怪助手",
              "nextStage": 5,
              "effect": "blame"
            },
            {
              "text": "没关系",
              "nextStage": 5,
              "effect": "forgive"
            }
          ]
        },
        {
          "stage": 5,
          "text": "硬币再也找不到了。",
          "options": []
        }
      ]
    },
    {
      "id": "item_teleprompter",
      "name": "提词器",
      "description": "写满演讲稿的提词器，但字迹模糊。",
      "storyline": [
        {
          "stage": 1,
          "text": "提词器突然黑屏。",
          "options": [
            {
              "text": "凭记忆演讲",
              "nextStage": 2,
              "effect": "memory"
            },
            {
              "text": "找备用提词器",
              "nextStage": 2,
              "effect": "spare"
            }
          ]
        },
        {
          "stage": 2,
          "text": "备用提词器也没电。",
          "options": [
            {
              "text": "即兴发挥",
              "nextStage": 3,
              "effect": "improv"
            },
            {
              "text": "看手稿",
              "nextStage": 3,
              "effect": "script"
            }
          ]
        },
        {
          "stage": 3,
          "text": "手稿被风吹走。",
          "options": [
            {
              "text": "追手稿",
              "nextStage": 4,
              "effect": "chase"
            },
            {
              "text": "放弃手稿",
              "nextStage": 4,
              "effect": "abandon"
            }
          ]
        },
        {
          "stage": 4,
          "text": "追手稿时摔倒。",
          "options": [
            {
              "text": "自嘲化解",
              "nextStage": 5,
              "effect": "selfdeprecate"
            },
            {
              "text": "愤怒指责",
              "nextStage": 5,
              "effect": "angry"
            }
          ]
        },
        {
          "stage": 5,
          "text": "观众觉得你滑稽。",
          "options": []
        }
      ]
    },
    {
      "id": "item_fake_news",
      "name": "假新闻稿",
      "description": "一份关于你的假新闻，但写得很有说服力。",
      "storyline": [
        {
          "stage": 1,
          "text": "你发现了假新闻稿。",
          "options": [
            {
              "text": "当场撕毁",
              "nextStage": 2,
              "effect": "tear"
            },
            {
              "text": "用来当草稿",
              "nextStage": 2,
              "effect": "draft"
            }
          ]
        },
        {
          "stage": 2,
          "text": "假新闻被记者捡到。",
          "options": [
            {
              "text": "解释是假的",
              "nextStage": 3,
              "effect": "explain"
            },
            {
              "text": "保持沉默",
              "nextStage": 3,
              "effect": "silence"
            }
          ]
        },
        {
          "stage": 3,
          "text": "记者公开质疑。",
          "options": [
            {
              "text": "提供证据",
              "nextStage": 4,
              "effect": "evidence"
            },
            {
              "text": "起诉诽谤",
              "nextStage": 4,
              "effect": "sue"
            }
          ]
        },
        {
          "stage": 4,
          "text": "证据不足，情况尴尬。",
          "options": [
            {
              "text": "转移话题",
              "nextStage": 5,
              "effect": "change_topic"
            },
            {
              "text": "承认疏失",
              "nextStage": 5,
              "effect": "admit"
            }
          ]
        },
        {
          "stage": 5,
          "text": "你的诚信受损。",
          "options": []
        }
      ]
    },
    {
      "id": "item_red_button",
      "name": "红色按钮",
      "description": "写着‘紧急情况按下’的按钮，但后果不明。",
      "storyline": [
        {
          "stage": 1,
          "text": "你看到红色按钮。",
          "options": [
            {
              "text": "按下它",
              "nextStage": 2,
              "effect": "press"
            },
            {
              "text": "不按",
              "nextStage": 2,
              "effect": "no_press"
            }
          ]
        },
        {
          "stage": 2,
          "text": "按钮触发舞台灯光秀。",
          "options": [
            {
              "text": "享受灯光",
              "nextStage": 3,
              "effect": "enjoy"
