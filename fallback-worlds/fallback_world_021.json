              "text": "道歉",
              "nextStage": 4,
              "effect": "apologize"
            }
          ]
        },
        {
          "stage": 4,
          "text": "你的支持率波动。",
          "options": [
            {
              "text": "强调正义",
              "nextStage": 5,
              "effect": "justice"
            },
            {
              "text": "低调处理",
              "nextStage": 5,
              "effect": "lowkey"
            }
          ]
        },
        {
          "stage": 5,
          "text": "事件逐渐平息。",
          "options": []
