  "npcs": [
    {
      "id": "npc_advisor",
      "name": "竞选顾问",
      "dialogue": "候选人！直播信号出问题了，15秒后全国直播！",
      "storyline": [
        {
          "stage": 1,
          "text": "顾问慌张地跑来：摄像机离线了！",
          "options": [
            {
              "text": "重启摄像机",
              "nextStage": 2,
              "effect": "fix_camera"
            },
            {
              "text": "用手机直播",
              "nextStage": 2,
              "effect": "phone_live"
            }
          ]
        },
        {
          "stage": 2,
          "text": "顾问：还有10秒！",
          "options": [
            {
              "text": "即兴演讲",
              "nextStage": 3,
              "effect": "speech"
            },
            {
              "text": "播放预备视频",
              "nextStage": 3,
              "effect": "video"
            }
          ]
        },
        {
          "stage": 3,
          "text": "直播开始，但观众发现你在厕所背景前。",
          "options": [
            {
              "text": "解释这是‘透明政府’",
              "nextStage": 4,
              "effect": "explain"
            },
            {
              "text": "关掉直播",
              "nextStage": 4,
              "effect": "shutdown"
            }
          ]
        },
        {
          "stage": 4,
          "text": "顾问叹气：你的支持率跌了10%。",
          "options": [
            {
              "text": "强硬挽回",
              "nextStage": 5,
              "effect": "tough"
            },
            {
              "text": "承认失误",
              "nextStage": 5,
              "effect": "admit"
            }
          ]
        },
        {
          "stage": 5,
          "text": "最终：你以微弱劣势输掉选举。",
          "options": []
        }
      ]
    },
    {
      "id": "npc_rival",
      "name": "竞争对手",
      "dialogue": "哼，你的直播真业余。",
      "storyline": [
        {
          "stage": 1,
          "text": "对手嘲笑你的技术故障。",
          "options": [
            {
              "text": "反击他的丑闻",
              "nextStage": 2,
              "effect": "counterattack"
            },
            {
              "text": "无视他",
              "nextStage": 2,
              "effect": "ignore"
            }
          ]
        },
        {
          "stage": 2,
          "text": "对手拿出你的黑历史。",
          "options": [
            {
              "text": "否认",
              "nextStage": 3,
              "effect": "deny"
            },
            {
              "text": "承认并道歉",
              "nextStage": 3,
              "effect": "apologize"
            }
          ]
        },
        {
          "stage": 3,
          "text": "观众哗然。",
          "options": [
            {
              "text": "转移话题到火星经济",
              "nextStage": 4,
              "effect": "economy"
            },
            {
              "text": "攻击对手政策",
              "nextStage": 4,
              "effect": "attack"
            }
          ]
        },
        {
          "stage": 4,
          "text": "辩论陷入混乱。",
          "options": [
            {
              "text": "优雅离场",
              "nextStage": 5,
              "effect": "exit"
            },
            {
              "text": "继续争吵",
              "nextStage": 5,
              "effect": "argue"
            }
          ]
        },
        {
          "stage": 5,
          "text": "你被视为不专业。",
          "options": []
        }
      ]
    },
    {
      "id": "npc_technician",
      "name": "技术员",
      "dialogue": "信号不稳！我需要时间！",
      "storyline": [
        {
          "stage": 1,
          "text": "技术员在修理设备。",
          "options": [
            {
              "text": "催促他",
              "nextStage": 2,
              "effect": "hurry"
            },
            {
              "text": "让他慢慢来",
              "nextStage": 2,
              "effect": "patient"
            }
          ]
        },
        {
          "stage": 2,
          "text": "设备冒烟了。",
          "options": [
            {
              "text": "用灭火器",
              "nextStage": 3,
              "effect": "fire"
            },
            {
              "text": "拔电源",
              "nextStage": 3,
              "effect": "unplug"
            }
          ]
        },
        {
          "stage": 3,
          "text": "直播中断5秒。",
          "options": [
            {
              "text": "即兴表演",
              "nextStage": 4,
              "effect": "improv"
            },
            {
              "text": "沉默等待",
              "nextStage": 4,
              "effect": "silence"
            }
          ]
        },
        {
          "stage": 4,
          "text": "技术员修好了。",
          "options": [
            {
              "text": "感谢他",
              "nextStage": 5,
              "effect": "thanks"
            },
            {
              "text": "责备他",
              "nextStage": 5,
              "effect": "blame"
            }
          ]
        },
        {
          "stage": 5,
          "text": "技术员辞职了。",
          "options": []
        }
      ]
    },
    {
      "id": "npc_reporter",
      "name": "记者",
      "dialogue": "候选人，您对刚才的故障有何评论？",
      "storyline": [
        {
          "stage": 1,
          "text": "记者咄咄逼人。",
          "options": [
            {
              "text": "幽默回应",
              "nextStage": 2,
              "effect": "humor"
            },
            {
              "text": "严肃回答",
              "nextStage": 2,
              "effect": "serious"
            }
          ]
        },
        {
          "stage": 2,
          "text": "记者追问更多。",
          "options": [
            {
              "text": "提供独家",
              "nextStage": 3,
              "effect": "exclusive"
            },
            {
              "text": "拒绝回答",
              "nextStage": 3,
              "effect": "refuse"
            }
          ]
        },
        {
          "stage": 3,
          "text": "记者爆料你的秘密。",
          "options": [
            {
              "text": "否认",
              "nextStage": 4,
              "effect": "deny"
            },
            {
              "text": "承认",
              "nextStage": 4,
              "effect": "confess"
            }
          ]
        },
        {
          "stage": 4,
          "text": "新闻标题对你很不利。",
          "options": [
            {
              "text": "起诉媒体",
              "nextStage": 5,
              "effect": "sue"
            },
            {
              "text": "接受采访",
              "nextStage": 5,
              "effect": "interview"
            }
          ]
        },
        {
          "stage": 5,
          "text": "你的形象受损。",
          "options": []
        }
      ]
    },
    {
      "id": "npc_supporter",
      "name": "支持者",
      "dialogue": "我们永远支持你！但这次直播……",
      "storyline": [
        {
          "stage": 1,
          "text": "支持者表示担忧。",
          "options": [
            {
              "text": "安抚他",
              "nextStage": 2,
              "effect": "calm"
            },
            {
              "text": "要求他帮忙",
              "nextStage": 2,
              "effect": "help"
            }
          ]
        },
        {
          "stage": 2,
          "text": "支持者愿意组织线下活动。",
          "options": [
            {
              "text": "同意",
              "nextStage": 3,
              "effect": "agree"
            },
            {
              "text": "拒绝，专注线上",
              "nextStage": 3,
              "effect": "decline"
            }
          ]
        },
        {
          "stage": 3,
          "text": "支持者被对手收买。",
          "options": [
            {
              "text": "揭露他",
              "nextStage": 4,
              "effect": "expose"
            },
            {
              "text": "原谅他",
              "nextStage": 4,
              "effect": "forgive"
            }
          ]
        },
        {
          "stage": 4,
          "text": "你的支持率波动。",
          "options": [
            {
              "text": "加大宣传",
              "nextStage": 5,
              "effect": "promote"
            },
            {
              "text": "调整策略",
              "nextStage": 5,
              "effect": "adjust"
            }
          ]
        },
        {
          "stage": 5,
          "text": "支持者群体分裂。",
          "options": []
        }
      ]
    }
  ],
  "items": [
    {
      "id": "item_lucky_coin",
      "name": "幸运硬币",
      "description": "一枚火星币，正面是你头像，背面是吉祥物。",
      "storyline": [
        {
          "stage": 1,
          "text": "你发现幸运硬币，也许能带来好运。",
          "options": [
            {
              "text": "带在身上",
              "nextStage": 2,
              "effect": "take"
            },
            {
              "text": "扔掉",
              "nextStage": 2,
              "effect": "discard"
            }
          ]
        },
        {
          "stage": 2,
          "text": "硬币掉落，滚向角落。",
          "options": [
            {
              "text": "捡起来",
