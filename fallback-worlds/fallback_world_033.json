  "npcs": [
    {
      "id": "npc_ceo_advisor",
      "name": "智囊先生",
      "position": [
        1,
        4
      ],
      "appearance": "西装革履，手持平板",
      "personality": "焦虑但专业",
      "storyline": [
        {
          "stage": 1,
          "text": "主席，外星买家即将到达，报价比预期低30%！",
          "options": [
            {
              "text": "接受报价，快速成交",
              "nextStage": 2
            },
            {
              "text": "拖延时间，寻找其他买家",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "明智选择，虽然亏了但保住了面子。",
          "options": [
            {
              "text": "准备签约仪式",
              "nextStage": 4
            },
            {
              "text": "要求附加条件",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "时间不多了，其他买家似乎不感兴趣。",
          "options": [
            {
              "text": "降价促销",
              "nextStage": 6
            },
            {
              "text": "威胁外星买家",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "签约仪式开始，但外星人要求看财务报表。",
          "options": [
            {
              "text": "提供虚假报表",
              "nextStage": 8
            },
            {
              "text": "实话实说",
              "nextStage": 9
            }
          ]
        },
        {
          "stage": 5,
          "text": "外星人同意附加条件，但要求更多土地。",
          "options": [
            {
              "text": "同意，反正都是他们的",
              "nextStage": 8
            },
            {
              "text": "拒绝，保护地球尊严",
              "nextStage": 9
            }
          ]
        },
        {
          "stage": 6,
          "text": "降价后外星人表示要考虑。",
          "options": [
            {
              "text": "继续施压",
              "nextStage": 7
            },
            {
              "text": "等待回复",
              "nextStage": 8
            }
          ]
        },
        {
          "stage": 7,
          "text": "威胁激怒了外星人，他们准备强行收购。",
          "options": [
            {
              "text": "投降",
              "nextStage": 8
            },
            {
              "text": "启动紧急防御",
              "nextStage": 9
            }
          ]
        },
        {
          "stage": 8,
          "text": "交易完成，地球易主。你被任命为地球管理者。",
          "fixedEnding": "ending_colonial_administrator"
        },
        {
          "stage": 9,
          "text": "谈判破裂，地球被毁灭。你成为历史罪人。",
          "fixedEnding": "ending_earth_destroyed"
        }
      ]
    },
    {
      "id": "npc_alien_buyer",
      "name": "赞特星代表",
      "position": [
        7,
        5
      ],
      "appearance": "蓝色皮肤，四只眼睛，穿着发光长袍",
      "personality": "傲慢且不耐烦",
      "storyline": [
        {
          "stage": 1,
          "text": "人类，我们时间有限。报价已经给出，接受或灭亡。",
          "options": [
            {
              "text": "诚惶诚恐地接受",
              "nextStage": 2
            },
            {
              "text": "试图讨价还价",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "很好，签约吧。你们地球的自然资源我们将高效利用。",
          "options": [
            {
              "text": "请求保留部分文化遗址",
              "nextStage": 4
            },
            {
              "text": "询问人类命运",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "讨价还价？愚蠢。我们决定降低报价10%以示惩罚。",
          "options": [
            {
              "text": "愤怒抗议",
              "nextStage": 6
            },
            {
              "text": "无奈接受",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 4,
          "text": "可以保留几个博物馆，但大部分土地将用于采矿。",
          "options": [
            {
              "text": "感谢",
              "nextStage": 7
            },
            {
              "text": "要求更多",
              "nextStage": 8
            }
          ]
        },
        {
          "stage": 5,
          "text": "人类将成为低等劳工，但不会被灭绝。",
          "options": [
            {
              "text": "接受，保命要紧",
              "nextStage": 7
            },
            {
              "text": "拒绝，宁愿战斗",
              "nextStage": 8
            }
          ]
        },
        {
          "stage": 6,
          "text": "抗议无效。我们技术远超你们。最后机会：接受或毁灭。",
          "options": [
            {
              "text": "接受",
              "nextStage": 7
            },
            {
              "text": "拒绝",
              "nextStage": 8
            }
          ]
        },
        {
          "stage": 7,
          "text": "合同签署。地球现在是赞特星的殖民地。",
          "fixedEnding": "ending_colonial_planet"
        },
        {
          "stage": 8,
          "text": "你们的选择导致地球毁灭。再见，愚蠢的文明。",
          "fixedEnding": "ending_annihilation"
        }
      ]
    },
    {
      "id": "npc_secretary",
      "name": "秘书小林",
      "position": [
        3,
        8
      ],
      "appearance": "OL装扮，戴着眼镜",
      "personality": "干练但紧张",
      "storyline": [
        {
          "stage": 1,
          "text": "主席，媒体已经在外面等候，需要您发布声明。",
          "options": [
            {
              "text": "发布乐观声明",
              "nextStage": 2
            },
            {
              "text": "发布悲观声明",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "媒体反应积极，但外星买家可能觉得我们太急切。",
          "options": [
            {
              "text": "继续炒作",
              "nextStage": 4
            },
            {
              "text": "低调处理",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "市场恐慌，地球股价暴跌。外星买家趁机压价。",
          "options": [
            {
              "text": "试图稳定市场",
              "nextStage": 5
            },
            {
              "text": "抛售个人股份",
              "nextStage": 6
            }
          ]
        },
        {
          "stage": 4,
          "text": "炒作过头，外星人认为我们急于出手，压低报价。",
          "options": [
            {
              "text": "接受低价",
              "nextStage": 6
            },
            {
              "text": "放弃交易",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 5,
          "text": "情况暂时稳定，但时间不多了。",
          "options": [
            {
              "text": "继续谈判",
              "nextStage": 6
            },
            {
              "text": "请教顾问",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 6,
          "text": "交易最终达成，你个人获得丰厚报酬，但地球命运已定。",
          "fixedEnding": "ending_personal_gain"
        },
        {
          "stage": 7,
          "text": "交易失败，你被问责，锒铛入狱。",
          "fixedEnding": "ending_imprisoned"
        }
      ]
    },
    {
      "id": "npc_activist",
      "name": "环保活动家",
      "position": [
        5,
        3
      ],
      "appearance": "穿着印有地球图案的T恤，举着标语",
      "personality": "愤怒且执着",
      "storyline": [
        {
          "stage": 1,
          "text": "你这个卖国贼！地球不是商品！",
          "options": [
            {
              "text": "试图解释",
              "nextStage": 2
            },
            {
              "text": "无视他",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "解释无效，他召集了更多抗议者。",
          "options": [
            {
              "text": "安抚抗议者",
              "nextStage": 4
            },
            {
              "text": "叫保安驱逐",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "他堵住了出口，要求你公开道歉。",
          "options": [
            {
              "text": "道歉",
              "nextStage": 4
            },
            {
              "text": "强硬拒绝",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "抗议暂时平息，但舆论压力增大。",
          "options": [
            {
              "text": "承诺环保条款",
              "nextStage": 6
            },
            {
              "text": "表面应付",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 5,
          "text": "暴力冲突升级，外星人借此指责人类不文明。",
          "options": [
            {
              "text": "控制局面",
              "nextStage": 6
            },
            {
              "text": "求助外星人",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 6,
          "text": "你成功平息抗议，交易继续进行。",
          "fixedEnding": "ending_smooth_deal"
        },
        {
          "stage": 7,
          "text": "抗议失控，外星人认为地球不稳定，取消收购并封锁地球。",
          "fixedEnding": "ending_quarantine"
        }
      ]
    },
    {
