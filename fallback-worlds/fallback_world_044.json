  "npcs": [
    {
      "id": "npc_001",
      "name": "量子CEO",
      "dialogue": "我来自另一个平行世界，我的公司市值是无限的。",
      "storyline": [
        {
          "stage": 1,
          "text": "量子CEO展示了他的量子计算机。",
          "options": [
            {
              "text": "询问技术细节",
              "nextStage": 2
            },
            {
              "text": "表示不屑",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "他解释说他的量子计算机可以计算所有平行世界的商业策略。",
          "options": [
            {
              "text": "要求合作",
              "nextStage": 4
            },
            {
              "text": "怀疑真实性",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "他生气地消失了，留下一个黑洞。",
          "options": [
            {
              "text": "跳入黑洞",
              "nextStage": 6
            },
            {
              "text": "远离黑洞",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "合作达成，你获得量子计算能力。",
          "options": [
            {
              "text": "感谢",
              "nextStage": -1
            },
            {
              "text": "继续探索",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 5,
          "text": "他证明了他的能力，预测了下一分钟的事件。",
          "options": [
            {
              "text": "相信他",
              "nextStage": 4
            },
            {
              "text": "仍然怀疑",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 6,
          "text": "你进入了一个全是CEO的平行世界。",
          "options": [
            {
              "text": "演讲",
              "nextStage": -1
            },
            {
              "text": "逃跑",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 7,
          "text": "黑洞消失了，量子CEO再也没出现。",
          "options": [
            {
              "text": "继续峰会",
              "nextStage": -1
            },
            {
              "text": "寻找他",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_002",
      "name": "时间管理者",
      "dialogue": "还有60秒，一切都会改变。",
      "storyline": [
        {
          "stage": 1,
          "text": "时间管理者滴答作响。",
          "options": [
            {
              "text": "加速时间",
              "nextStage": 2
            },
            {
              "text": "减速时间",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "时间加速，你看到未来。",
          "options": [
            {
              "text": "利用信息",
              "nextStage": 4
            },
            {
              "text": "避免未来",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "时间减速，你获得更多思考时间。",
          "options": [
            {
              "text": "制定计划",
              "nextStage": 6
            },
            {
              "text": "放松",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "你预知了峰会结果，成为赢家。",
          "options": [
            {
              "text": "接受胜利",
              "nextStage": -1
            },
            {
              "text": "改变结果",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 5,
          "text": "你试图改变，但时间不可逆。",
          "options": [
            {
              "text": "放弃",
              "nextStage": -1
            },
            {
              "text": "继续努力",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 6,
          "text": "你制定了完美计划。",
          "options": [
            {
              "text": "执行",
              "nextStage": -1
            },
            {
              "text": "修改",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 7,
          "text": "你错过了时间，峰会开始。",
          "options": [
            {
              "text": "匆忙入场",
              "nextStage": -1
            },
            {
              "text": "放弃参加",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_003",
      "name": "镜像顾问",
      "dialogue": "你的每个选择都创造一个新世界。",
      "storyline": [
