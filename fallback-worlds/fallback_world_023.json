            {
              "text": "你疯了？我们应该逃！",
              "nextStage": 2,
              "effect": "逃"
            }
          ]
        },
        {
          "stage": 1,
          "dialog": "好，这里有红色按钮和绿色按钮…",
          "options": [
            {
              "text": "按红色",
              "nextStage": "ending_success",
              "effect": "成功制动"
            },
            {
              "text": "按绿色",
              "nextStage": "ending_fail",
              "effect": "加速坠落"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "逃？电梯正在下坠，逃不掉了！",
          "options": [
            {
              "text": "我有个计划",
              "nextStage": 1,
              "effect": "回头"
            },
            {
              "text": "那就一起等死吧",
              "nextStage": "ending_death",
              "effect": "放弃"
            }
          ]
        }
      ]
    },
