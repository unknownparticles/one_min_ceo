        {
          "stage": 3,
          "text": "投资人冷笑，身后出现一群打手。",
          "options": [
            {
              "text": "投降被抓",
              "effect": "arrested_end"
            },
            {
              "text": "从后门逃跑",
              "effect": "escape_backdoor"
            }
          ]
        }
      ],
      "position": [
        2,
        11
      ]
    },
    {
      "id": "np_security_01",
      "name": "安全主管达克",
      "type": "security",
      "dailogue": "老板，系统被入侵了！",
      "storyline": [
        {
          "stage": 1,
          "text": "达克慌张地跑来报告。",
          "options": [
            {
              "text": "查看监控",
              "effect": "see_intruder"
            },
            {
              "text": "重启系统",
              "effect": "reboot"
            }
          ]
        },
        {
          "stage": 2,
          "text": "他发现入侵者是你自己的账号。",
          "options": [
            {
              "text": "承认并解释",
              "effect": "explain"
            },
            {
              "text": "否认",
              "effect": "deny"
            }
          ]
        },
        {
          "stage": 3,
          "text": "达克拔出电击棒。",
          "options": [
            {
              "text": "制服他",
              "effect": "fight_security"
            },
            {
              "text": "求饶",
              "effect": "beg"
            }
          ]
        }
      ],
      "position": [
        5,
        13
      ]
