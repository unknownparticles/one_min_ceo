  "npcs": [
    {
      "id": "np_guard_01",
      "name": "保安队长巴特",
      "type": "guard",
      "dialogue": "老板，赌场外面全是债主！",
      "storyline": [
        {
          "stage": 1,
          "text": "巴特神色紧张地拦住你。",
          "options": [
            {
              "text": "安抚他",
              "effect": "gain_stamina"
            },
            {
              "text": "命令他开路",
              "effect": "lose_trust"
            }
          ]
        },
        {
          "stage": 2,
          "text": "他递给你一张字条，上面写着'快走'。",
          "options": [
            {
              "text": "收下字条",
              "effect": "gain_clue"
            },
            {
              "text": "撕掉字条",
              "effect": "lose_clue"
            }
          ]
        },
        {
          "stage": 3,
          "text": "巴特突然掏出一把枪对准你。",
          "options": [
            {
              "text": "举双手投降",
              "effect": "arrested_end"
            },
            {
              "text": "扑上去夺枪",
              "effect": "fight_guard"
            }
          ]
        }
      ],
      "position": [
        1,
        2
      ]
    },
    {
      "id": "np_dealer_01",
      "name": "荷官莉莉丝",
      "type": "dealer",
      "dialogue": "老板，最后一局了，要玩吗？",
      "storyline": [
        {
          "stage": 1,
          "text": "莉莉丝微笑着洗牌。",
          "options": [
            {
              "text": "玩一把",
              "effect": "gamble_money"
            },
            {
              "text": "拒绝",
              "effect": "gain_time"
            }
          ]
        },
        {
          "stage": 2,
          "text": "她悄悄塞给你一张黑卡。",
          "options": [
            {
              "text": "收下黑卡",
              "effect": "gain_escape_money"
            },
            {
              "text": "退回",
              "effect": "lose_opportunity"
            }
          ]
        },
        {
          "stage": 3,
          "text": "莉莉丝突然掀翻桌子，露出下面的传送门。",
          "options": [
            {
              "text": "跳进传送门",
              "effect": "escape_ending"
            },
            {
              "text": "犹豫不决",
              "effect": "miss_chance"
            }
          ]
        }
      ],
      "position": [
        3,
        8
      ]
    },
    {
      "id": "np_robot_01",
      "name": "机器人管家小Q",
      "type": "robot",
      "dialogue": "主人，您的飞船已经准备好了。",
      "storyline": [
        {
          "stage": 1,
          "text": "小Q端着一杯咖啡出现。",
          "options": [
            {
              "text": "喝咖啡",
              "effect": "gain_energy"
            },
            {
              "text": "打翻咖啡",
              "effect": "lose_energy"
            }
          ]
        },
        {
          "stage": 2,
          "text": "它展示了一条秘密通道。",
          "options": [
            {
              "text": "跟随小Q",
              "effect": "secret_path"
            },
            {
              "text": "不信任它",
              "effect": "stay_put"
            }
          ]
        },
        {
          "stage": 3,
          "text": "小Q突然短路，开始重复播放一段代码。",
          "options": [
            {
              "text": "解读代码",
              "effect": "get_code"
            },
            {
              "text": "关机重启",
              "effect": "lose_code"
            }
          ]
        }
      ],
      "position": [
        4,
        4
      ]
    },
    {
      "id": "np_investor_01",
      "name": "神秘投资人",
      "type": "investor",
      "dialogue": "你的赌场要破产了，我可以收购。",
      "storyline": [
        {
          "stage": 1,
          "text": "投资人坐在豪华沙发上。",
          "options": [
            {
              "text": "谈判",
              "effect": "negotiate_deal"
            },
            {
              "text": "拒绝",
              "effect": "no_deal"
            }
          ]
        },
        {
          "stage": 2,
          "text": "他开出一张空头支票。",
          "options": [
            {
              "text": "接受支票",
              "effect": "fake_money"
            },
            {
              "text": "要求现金",
              "effect": "real_money"
            }
          ]
