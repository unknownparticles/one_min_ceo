  "npcs": [
    {
      "id": "npc_1",
      "name": "星系富豪",
      "x": 2,
      "y": 2,
      "storyline": [
        {
          "stage": 1,
          "dialog": "年轻人，这枚星核是我的！",
          "options": [
            {
              "text": "竞价加价",
              "effect": "add_time_10"
            },
            {
              "text": "放弃竞价",
              "effect": "remove_item_star_core"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "你以为你能赢？我还有后手！",
          "options": [
            {
              "text": "亮出底牌",
              "effect": "add_score_500"
            },
            {
              "text": "拖延时间",
              "effect": "add_time_5"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "我认输，但别得意太早。",
          "options": [
            {
              "text": "接受认输",
              "effect": "add_score_1000"
            },
            {
              "text": "嘲讽他",
              "effect": "remove_score_200"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_2",
      "name": "星际收藏家",
      "x": 3,
      "y": 5,
      "storyline": [
        {
          "stage": 1,
          "dialog": "这颗星球上的古董是我的！",
          "options": [
            {
              "text": "用金币压他",
              "effect": "add_time_15"
            },
            {
              "text": "威胁他",
              "effect": "remove_npc"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "你休想得到！",
          "options": [
            {
              "text": "出示凭证",
              "effect": "add_score_300"
            },
            {
              "text": "无视他",
              "effect": "add_time_5"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "好吧，你赢了。",
          "options": [
            {
              "text": "继续竞价",
              "effect": "add_score_500"
            },
            {
              "text": "离开",
              "effect": "end_game"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_3",
      "name": "宇宙拍卖师",
      "x": 7,
      "y": 4,
      "storyline": [
        {
          "stage": 1,
          "dialog": "竞价开始！底价100万星币！",
          "options": [
            {
              "text": "直接出价200万",
              "effect": "add_score_200"
            },
            {
              "text": "观察局势",
              "effect": "add_time_5"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "还有更高的吗？",
          "options": [
            {
              "text": "出价300万",
              "effect": "add_score_300"
            },
            {
              "text": "等待倒计时",
              "effect": "add_time_10"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "成交！恭喜你获得星核！",
          "options": [
            {
              "text": "感谢拍卖师",
              "effect": "add_score_1000"
            },
            {
              "text": "转身离开",
              "effect": "end_game"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_4",
      "name": "神秘买家",
      "x": 9,
      "y": 3,
      "storyline": [
        {
          "stage": 1,
          "dialog": "我代表暗影帝国，放弃竞价。",
          "options": [
            {
              "text": "虚张声势",
              "effect": "add_score_100"
            },
            {
              "text": "相信他",
              "effect": "add_time_10"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "但我有条件。",
          "options": [
            {
              "text": "什么条件？",
              "effect": "reveal_secret"
            },
            {
              "text": "不需要条件",
              "effect": "add_score_200"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "合作愉快。",
          "options": [
            {
              "text": "握手",
              "effect": "add_score_500"
            },
            {
              "text": "保持警惕",
              "effect": "add_time_5"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_5",
      "name": "机器人管家",
      "x": 5,
      "y": 8,
      "storyline": [
        {
          "stage": 1,
          "dialog": "主人，您有一封紧急消息。",
          "options": [
            {
              "text": "查看消息",
              "effect": "reveal_clue"
            },
            {
              "text": "先竞价",
              "effect": "add_time_5"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "是董事会要求您放弃竞拍。",
          "options": [
            {
              "text": "拒绝董事会",
              "effect": "add_score_200"
            },
            {
              "text": "假装同意",
              "effect": "add_time_10"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "我已按您吩咐回复了。",
          "options": [
            {
              "text": "做得好",
              "effect": "add_score_100"
            },
            {
              "text": "沉默",
              "effect": "add_time_5"
            }
          ]
        }
      ]
    }
  ],
  "items": [
    {
      "id": "item_1",
      "name": "星核",
      "x": 10,
      "y": 2,
      "storyline": [
        {
          "stage": 1,
          "text": "一颗蕴含巨大能量的星核。",
          "options": [
            {
              "text": "拿起星核",
              "effect": "add_score_500"
            },
            {
              "text": "检查真假",
              "effect": "reveal_secret"
            }
          ]
        },
        {
          "stage": 2,
          "text": "它似乎在震动。",
          "options": [
            {
              "text": "用能量吸收器",
              "effect": "add_score_300"
            },
            {
              "text": "放回原处",
              "effect": "remove_item_star_core"
            }
          ]
        },
        {
          "stage": 3,
          "text": "星核认可了你。",
          "options": [
            {
              "text": "吸收能量",
              "effect": "add_score_1000"
            },
            {
              "text": "保留收藏",
              "effect": "add_item_star_core"
            }
          ]
        }
      ]
    },
    {
      "id": "item_2",
      "name": "古董星球",
      "x": 4,
      "y": 7,
      "storyline": [
        {
          "stage": 1,
          "text": "一个微型星球古董。",
          "options": [
