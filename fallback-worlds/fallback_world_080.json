            {
              "text": "忽略文字",
              "effect": "add_time_5"
            }
          ]
        },
        {
          "stage": 3,
          "text": "文字记载了宝藏位置。",
          "options": [
            {
              "text": "记下位置",
              "effect": "add_score_800"
            },
            {
              "text": "公开消息",
              "effect": "remove_score_200"
            }
          ]
        }
      ]
    },
    {
      "id": "item_3",
      "name": "能量剑",
      "x": 8,
      "y": 5,
      "storyline": [
        {
          "stage": 1,
          "text": "一把古老的能量剑。",
          "options": [
            {
              "text": "挥舞试试",
              "effect": "add_score_100"
            },
            {
              "text": "小心保管",
              "effect": "add_item_energy_sword"
            }
          ]
        },
        {
          "stage": 2,
          "text": "剑刃发出嗡鸣。",
          "options": [
            {
              "text": "充能",
              "effect": "add_score_300"
            },
            {
              "text": "收起来",
              "effect": "add_time_5"
            }
          ]
        },
        {
          "stage": 3,
          "text": "它认你为主。",
          "options": [
            {
              "text": "装备它",
              "effect": "add_score_600"
            },
            {
              "text": "拍卖它",
              "effect": "add_score_200"
            }
          ]
        }
      ]
    },
    {
      "id": "item_4",
      "name": "星际地图",
      "x": 6,
      "y": 2,
      "storyline": [
        {
          "stage": 1,
          "text": "一张标注了未知星域的古老地图。",
          "options": [
            {
              "text": "研究地图",
              "effect": "reveal_secret"
            },
            {
              "text": "收起地图",
              "effect": "add_item_star_map"
            }
          ]
        },
        {
          "stage": 2,
          "text": "图上有一个红点。",
          "options": [
            {
              "text": "前往红点",
              "effect": "add_score_400"
            },
            {
              "text": "标记坐标",
              "effect": "add_time_10"
            }
          ]
        },
        {
          "stage": 3,
          "text": "红点处埋藏着宝藏。",
          "options": [
            {
              "text": "挖掘宝藏",
              "effect": "add_score_1000"
            },
            {
              "text": "报告上级",
              "effect": "add_score_200"
            }
          ]
        }
      ]
    },
    {
      "id": "item_5",
      "name": "神秘药剂",
      "x": 11,
      "y": 8,
      "storyline": [
        {
          "stage": 1,
          "text": "一瓶闪烁着星光的药剂。",
          "options": [
            {
              "text": "一饮而尽",
              "effect": "add_time_30"
            },
            {
              "text": "分析成分",
              "effect": "reveal_clue"
            }
          ]
        },
        {
          "stage": 2,
          "text": "药剂能短暂提升感知。",
          "options": [
            {
              "text": "使用药剂",
              "effect": "add_score_500"
            },
            {
              "text": "保存备用",
              "effect": "add_item_potion"
            }
          ]
        },
        {
          "stage": 3,
          "text": "副作用是头晕。",
          "options": [
            {
              "text": "硬撑",
              "effect": "add_score_200"
            },
            {
              "text": "休息一下",
              "effect": "remove_time_10"
            }
          ]
        }
      ]
    }
  ],
  "fixedEndings": [
    {
      "id": "ending_1",
      "condition": "score >= 1000",
      "text": "你成功拍得星核，成为宇宙最富有的人之一。",
      "effect": "win"
    },
    {
      "id": "ending_2",
      "condition": "time <= 0",
      "text": "时间到！竞价失败，你失去了所有机会。",
      "effect": "lose"
    },
    {
      "id": "ending_3",
      "condition": "has_item('star_core') && score >= 500",
      "text": "你带着星核逃离拍卖行，但被通缉。",
      "effect": "neutral"
    },
    {
      "id": "ending_4",
      "condition": "npc_removed >= 3",
      "text": "你得罪了太多买家，被逐出拍卖行。",
      "effect": "lose"
    },
    {
      "id": "ending_5",
      "condition": "score >= 2000",
      "text": "你不仅拍得星核，还获得了神秘组织的青睐。",
      "effect": "win_bonus"
    },
    {
      "id": "ending_6",
      "condition": "has_item('energy_sword') && has_item('star_map')",
      "text": "你利用地图和剑找到了隐藏宝藏，成为传奇。",
      "effect": "win_epic"
    },
    {
      "id": "ending_7",
      "condition": "score < 0",
      "text": "你负债累累，被迫卖身给拍卖行。",
      "effect": "lose"
    },
    {
      "id": "ending_8",
      "condition": "time >= 60",
      "text": "你拖延了时间，拍卖被取消，一切归零。",
      "effect": "neutral"
    },
    {
      "id": "ending_9",
      "condition": "score >= 1500 && npc_removed == 0",
      "text": "你凭借智慧和礼貌赢得了所有人的尊重。",
      "effect": "win_honor"
    }
  ],
  "introText": "欢迎来到宇宙拍卖行！你作为CEO，必须在60秒内竞拍下稀世星核。注意时间，做出选择！",
  "ambientMusic": "epic_auction_theme",
  "id": "fallback_world_080"
}