    {
      "id": "end_14",
      "text": "财富永存，但孤独终老，所有亲人离去。"
    },
    {
      "id": "end_15",
      "text": "权力永恒，但世界陷入黑暗，你成为独裁者。"
    },
    {
      "id": "end_16",
      "text": "一切虚无，但内心平静，超脱世俗。"
    },
    {
      "id": "end_17",
      "text": "逮捕盟友，财阀内乱，但核心稳定。"
    },
    {
      "id": "end_18",
      "text": "原谅盟友，他感恩戴德，成为忠诚助手。"
    },
    {
      "id": "end_19",
      "text": "追回数据，但盟友反目成仇，财阀分裂。"
    },
    {
      "id": "end_20",
      "text": "放弃数据，财阀科技落后，但保全和谐。"
    },
    {
      "id": "end_21",
      "text": "战斗胜利，但时间耗尽，陷入黑暗。"
    },
    {
      "id": "end_22",
      "text": "躲避成功，赢得时间，但失去电源。"
    },
    {
      "id": "end_23",
      "text": "保留电源到停电后，却无处可用。"
    },
    {
      "id": "end_24",
      "text": "公开秘密，震惊世界，财阀成为焦点。"
    },
    {
      "id": "end_25",
      "text": "隐藏秘密，安全度过，但秘密永沉。"
    },
    {
      "id": "end_26",
      "text": "后悔不已，但时光不再，只能接受。"
    },
    {
      "id": "end_27",
      "text": "无所谓，继续前行，但错失良机。"
    },
    {
      "id": "end_28",
      "text": "忍受副作用，决策加速，但记忆混乱。"
    },
    {
      "id": "end_29",
      "text": "移除接口，恢复原状，但失去优势。"
    },
    {
      "id": "end_30",
      "text": "修复失败，接口报废，一无所获。"
    },
    {
      "id": "end_31",
      "text": "放弃，没有接口也能活，但效率降低。"
    },
    {
      "id": "end_32",
      "text": "等待救援，却无人来，最终困死。"
    },
    {
      "id": "end_33",
      "text": "强行破门，成功逃脱，但受伤严重。"
    },
    {
      "id": "end_34",
      "text": "迎战敌人，英勇就义，成为传奇。"
    },
    {
      "id": "end_35",
      "text": "逃跑成功，但财阀基业毁于一旦。"
    },
    {
      "id": "end_36",
      "text": "巩固地位，财阀永续，但代价巨大。"
    },
    {
      "id": "end_37",
      "text": "分享权力，建立联盟，实现共治。"
    },
    {
      "id": "end_38",
      "text": "重建财阀，白手起家，重获辉煌。"
    },
    {
      "id": "end_39",
      "text": "归隐田园，平淡生活，远离纷争。"
    }
  ],
  "introText": "欢迎来到赛博东京，财阀大人！全市将在60秒后停电，你的帝国岌岌可危。在这最后的时间里，你必须做出决策，确保财阀的存续。记住，每一秒都至关重要！",
  "ambientMusic": "cyberpunk_emergency.mp3",
  "id": "fallback_world_022"
}