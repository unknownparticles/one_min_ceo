  "npcs": [
    {
      "id": "npc1",
      "name": "审计官克罗",
      "dialogue": "你好，CEO。",
      "storyline": [
        {
          "stage": 1,
          "text": "审计官克罗突然出现在你面前，手中拿着一个发光的平板。",
          "options": [
            {
              "text": "热情打招呼",
              "effect": "克罗好感+1"
            },
            {
              "text": "假装没看见",
              "effect": "克罗好感-1"
            }
          ]
        },
        {
          "stage": 2,
          "text": "克罗开始询问你关于时间流稳定性报告的问题。",
          "options": [
            {
              "text": "详细解释报告",
              "effect": "审计进度-10%"
            },
            {
              "text": "转移话题",
              "effect": "克罗怀疑+1"
            }
          ]
        },
        {
          "stage": 3,
          "text": "克罗指出了报告中的一处矛盾。",
          "options": [
            {
              "text": "承认错误并道歉",
              "effect": "审计进度-20%"
            },
            {
              "text": "狡辩说是系统错误",
              "effect": "克罗愤怒+1"
            }
          ]
        }
      ],
      "position": [
        5,
        6
      ]
    },
    {
      "id": "npc2",
      "name": "影子秘书",
      "dialogue": "先生，需要咖啡吗？",
      "storyline": [
        {
          "stage": 1,
          "text": "你的影子秘书端着一杯冒着绿光的咖啡靠近。",
          "options": [
            {
              "text": "接过咖啡",
              "effect": "获得物品：可疑咖啡"
            },
            {
              "text": "拒绝",
              "effect": "秘书失望"
            }
          ]
        },
        {
          "stage": 2,
          "text": "秘书悄声说：'我听说审计官喜欢收集古董。'",
          "options": [
            {
              "text": "询问更多细节",
              "effect": "获得情报"
            },
            {
              "text": "不感兴趣",
              "effect": "无"
            }
          ]
        },
        {
          "stage": 3,
          "text": "秘书掏出一个怀表：'这是我在仓库找到的，或许有用。'",
          "options": [
            {
              "text": "收下怀表",
              "effect": "获得物品：古董怀表"
            },
            {
              "text": "让她放回去",
              "effect": "秘书不解"
            }
          ]
        }
      ],
      "position": [
        5,
        2
      ]
    },
    {
      "id": "npc3",
      "name": "时间保安队长",
      "dialogue": "长官，一切正常。",
      "storyline": [
        {
          "stage": 1,
          "text": "队长敬礼：'报告CEO，安保系统已全面升级。'",
          "options": [
            {
              "text": "表示赞许",
              "effect": "队长忠诚+1"
            },
            {
              "text": "质疑他的效率",
              "effect": "队长沮丧"
            }
          ]
        },
        {
          "stage": 2,
          "text": "队长压低声音：'我听说有人想破坏审计。'",
          "options": [
            {
              "text": "命令他加强警戒",
              "effect": "安保等级+1"
            },
            {
              "text": "让他别管闲事",
              "effect": "队长失望"
            }
          ]
        },
        {
          "stage": 3,
          "text": "队长递给你一份可疑人员名单。",
          "options": [
            {
              "text": "仔细阅读名单",
              "effect": "获得情报"
            },
            {
              "text": "随手扔进垃圾桶",
              "effect": "错过线索"
            }
          ]
        }
      ],
      "position": [
        8,
        2
      ]
    },
    {
      "id": "npc4",
      "name": "中央计算机",
      "dialogue": "哔——系统自检中。",
      "storyline": [
        {
          "stage": 1,
          "text": "中央计算机发出警报：'检测到未授权时间旅行！'",
          "options": [
            {
              "text": "立即调查",
              "effect": "审计进度+10%"
