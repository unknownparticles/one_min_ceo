        {
          "stage": 3,
          "text": "清洁工低声说：'我见过审计官……他们不喜欢混乱。'",
          "options": [
            {
              "text": "询问如何应对",
              "effect": "获得提示"
            },
            {
              "text": "不以为然",
              "effect": "无"
            }
          ]
        }
      ],
      "position": [
        9,
        12
      ]
