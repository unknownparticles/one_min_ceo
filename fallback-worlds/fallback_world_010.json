          ]
        },
        {
          "stage": 2,
          "text": "计算机屏幕闪烁：'建议启动应急协议。'",
          "options": [
            {
              "text": "启动协议",
              "effect": "获得临时权限"
            },
            {
              "text": "否决建议",
              "effect": "无"
            }
          ]
        },
        {
          "stage": 3,
          "text": "计算机显示：'审计官预计在30秒后抵达。'",
          "options": [
            {
              "text": "深呼吸准备",
              "effect": "冷静+1"
            },
            {
              "text": "慌乱奔跑",
              "effect": "混乱+1"
            }
          ]
        }
      ],
      "position": [
        2,
        8
      ]
    },
    {
      "id": "npc5",
      "name": "时间褶皱清洁工",
      "dialogue": "这里好脏啊。",
      "storyline": [
        {
          "stage": 1,
          "text": "清洁工正在用吸尘器吸走时间碎片。",
          "options": [
            {
              "text": "问他发现了什么",
              "effect": "获得碎片情报"
            },
            {
              "text": "让他专心工作",
              "effect": "清洁工无视你"
            }
          ]
        },
        {
          "stage": 2,
          "text": "清洁工举起一块发光的碎片：'这个很特别。'",
          "options": [
            {
              "text": "索要碎片",
              "effect": "获得物品：时间碎片"
