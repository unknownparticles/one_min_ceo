  "fixedEndings": [
    {
      "id": "ending1",
      "trigger": "审计进度达到100%",
      "text": "审计官满意地点头，宣布时空管理局运行良好。你保住了CEO的位置。"
    },
    {
      "id": "ending2",
      "trigger": "审计进度低于0%",
      "text": "审计官发现严重违规，当场撤销你的资格。你被流放到时间裂缝。"
    },
    {
      "id": "ending3",
      "trigger": "使用应急按钮重置世界",
      "text": "一切回到60秒前，但你的记忆保留。你有了第二次机会。"
    },
    {
      "id": "ending4",
      "trigger": "喝下可疑咖啡后选择错误选项",
      "text": "你陷入幻觉，在审计官面前胡言乱语。审计失败。"
    },
    {
      "id": "ending5",
      "trigger": "成功使用怀表暂停时间并完成审计",
      "text": "你利用时间暂停完美通过了审计。但怀表碎裂，时空出现涟漪。"
    },
    {
      "id": "ending6",
      "trigger": "收集所有时间碎片并合成",
      "text": "你合成了完整的时间结晶，拥有了控制时间的能力。审计官敬畏地离开。"
    },
    {
      "id": "ending7",
      "trigger": "与影子秘书好感度满",
      "text": "秘书实际上是一位时间守护者，她帮你化解了审计危机。"
    },
    {
      "id": "ending8",
      "trigger": "触发自毁程序",
      "text": "整个时空管理局爆炸，你与审计官一同消失在时间洪流中。"
    },
    {
      "id": "ending9",
      "trigger": "输入数字42到控制台",
      "text": "你解锁了隐藏的真相：宇宙的答案是42，审计官被这个答案折服。"
    },
    {
      "id": "ending10",
      "trigger": "拒绝所有NPC的提议",
      "text": "你保持沉默，审计官认为你高深莫测，决定延期审计。"
    }
  ],
  "introText": "你，时空管理局CEO，正坐在办公室。突然，警报响起：审计官将在60秒后抵达！你必须在这60秒内处理危机，整理报告，或者……用非常手段。时间开始倒数！",
  "ambientMusic": "紧张而急促的电子音乐，夹杂时钟滴答声",
  "id": "fallback_world_010"
}