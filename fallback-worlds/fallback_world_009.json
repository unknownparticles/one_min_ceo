    {
      "id": "npc_engineer",
      "name": "首席工程师王工",
      "dialogue": "反应堆温度异常！",
      "storyline": [
        {
          "stage": 0,
          "text": "王工焦急地说：'反应堆核心温度已超过临界值！'",
          "options": [
            {
              "text": "冷静分析",
              "nextStage": 1
            },
            {
              "text": "立刻疏散",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "text": "你分析数据，发现是冷却系统故障。",
          "options": [
            {
              "text": "手动重启冷却",
              "nextStage": 3
            },
            {
              "text": "呼叫紧急支援",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 2,
          "text": "疏散警报响起，发布会陷入混乱。",
          "options": [
            {
              "text": "安抚群众",
              "nextStage": 3
            },
            {
              "text": "逃跑",
              "nextStage": 4
            }
          ]
        },
        {
          "stage": 3,
          "text": "你成功重启冷却，温度下降。但爆炸物依然存在。",
          "options": [
            {
              "text": "寻找爆炸物",
              "nextStage": 4
            },
            {
              "text": "报警",
              "nextStage": 4
            }
          ]
        },
        {
          "stage": 4,
          "text": "终局：要么成功排除危机，要么爆炸。",
          "options": [
            {
              "text": "继续",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
