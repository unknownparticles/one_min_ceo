        },
        {
          "stage": 2,
          "text": "大卫拿走支票，但爆炸迫近。",
          "options": [
            {
              "text": "寻找出口",
              "nextStage": 3
            },
            {
              "text": "抢回支票",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "混乱中，大卫被绊倒。",
          "options": [
            {
              "text": "扶他",
              "nextStage": 4
