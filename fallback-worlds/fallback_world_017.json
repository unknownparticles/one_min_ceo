      "id": "npc_001",
      "name": "赌场经理",
      "dialogue": {
        "greeting": "老板！账上只剩60秒了！",
        "stages": [
          {
            "stage": 1,
            "text": "你疯狂地翻着账本，数字在跳动。",
            "options": [
