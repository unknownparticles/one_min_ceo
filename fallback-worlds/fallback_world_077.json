  "npcs": [
    {
      "id": "npc_scientist",
      "name": "首席科学家李维",
      "position": [
        1,
        3
      ],
      "dialogue": "太阳即将熄灭！我们还有60秒！",
      "storyline": [
        {
          "stage": 1,
          "text": "我们必须启动备用能源！但需要密码。",
          "options": [
            {
              "text": "密码是多少？",
              "nextStage": 2
            },
            {
              "text": "我去找密码。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "密码藏在会议室的花盆里。",
          "options": [
            {
              "text": "我去拿。",
              "nextStage": 3
            },
            {
              "text": "你确定？",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "快去！时间不多了！",
          "options": [
            {
              "text": "收到！",
              "nextStage": "end"
            },
            {
              "text": "还有其他办法吗？",
              "nextStage": "end"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_general",
      "name": "将军张猛",
      "position": [
        2,
        3
      ],
      "dialogue": "所有部队待命，但我们需要指令！",
      "storyline": [
        {
          "stage": 1,
          "text": "太阳熄灭后，社会秩序会崩溃。",
          "options": [
            {
              "text": "启动军事管制。",
              "nextStage": 2
            },
            {
              "text": "等待进一步指示。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "已经下令，但需要最高授权。",
          "options": [
            {
              "text": "我授权。",
              "nextStage": "end"
            },
            {
              "text": "再想想。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "时间紧迫！",
          "options": [
            {
              "text": "立即行动！",
              "nextStage": "end"
            },
            {
              "text": "再等等。",
              "nextStage": "end"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_engineer",
      "name": "总工程师王工",
      "position": [
        3,
        3
      ],
      "dialogue": "备用发电机故障！需要手动重启。",
      "storyline": [
        {
          "stage": 1,
          "text": "发电机在地下室，但需要钥匙。",
          "options": [
            {
              "text": "钥匙在哪？",
              "nextStage": 2
            },
            {
              "text": "我去看看。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "在安全主管身上。",
          "options": [
            {
              "text": "去找他。",
              "nextStage": 3
            },
            {
              "text": "强行启动。",
              "nextStage": "end"
            }
          ]
        },
        {
          "stage": 3,
          "text": "你要小心，那里很危险。",
          "options": [
            {
              "text": "我准备好了。",
              "nextStage": "end"
            },
            {
              "text": "派别人去。",
              "nextStage": "end"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_secretary",
      "name": "秘书小刘",
      "position": [
        1,
        7
      ],
      "dialogue": "主席，您的咖啡准备好了。",
      "storyline": [
        {
          "stage": 1,
          "text": "但我觉得现在不是喝咖啡的时候。",
          "options": [
            {
              "text": "说得对，取消。",
              "nextStage": 2
            },
            {
              "text": "给我吧，我需要提神。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "好的，我去通知大家准备疏散。",
          "options": [
            {
              "text": "去吧。",
              "nextStage": "end"
            },
            {
              "text": "等等，还有事。",
              "nextStage": "end"
            }
          ]
        },
        {
          "stage": 3,
          "text": "咖啡很烫，小心。",
          "options": [
            {
              "text": "谢谢。",
              "nextStage": "end"
            },
            {
              "text": "放下吧。",
              "nextStage": "end"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_strategist",
      "name": "策略师陈思",
      "position": [
        2,
        7
      ],
      "dialogue": "我们应该启动长期休眠计划。",
      "storyline": [
        {
          "stage": 1,
          "text": "但需要所有部门的同意。",
          "options": [
            {
              "text": "我同意。",
              "nextStage": 2
            },
            {
              "text": "反对，还有希望。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "太好了，我这就去准备。",
          "options": [
            {
              "text": "快去吧。",
              "nextStage": "end"
            },
            {
              "text": "再确认一下。",
              "nextStage": "end"
            }
          ]
        },
        {
          "stage": 3,
          "text": "那您有什么高见？",
          "options": [
            {
              "text": "启动备用能源。",
              "nextStage": "end"
            },
            {
              "text": "听天由命。",
              "nextStage": "end"
            }
          ]
        }
      ]
    }
