      "id": "ending9",
      "condition": "找到扫地僧的秘密金库",
      "description": "你发现真正的财富，但失去了帝国。"
    },
    {
      "id": "ending10",
      "condition": "完全听从预言家",
      "description": "预言成真，你无力回天。"
    }
