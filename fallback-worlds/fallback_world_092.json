  "npcs": [
    {
      "id": "npc_dimension_auditor",
      "name": "降维审计官",
      "appearance": "身着银色长袍，面无表情，手持发光平板",
      "dialogue": "你的公司将在60秒后接受降维考核，准备好迎接终局了吗？",
      "storyline": [
        {
          "stage": 1,
          "text": "审计官冷漠地扫视你：'所有数据将被实时评估，你的每一个决策都将影响文明等级。'",
          "options": [
            {
              "text": "展示你最得意的产品",
              "nextStage": 2
            },
            {
              "text": "请求延长准备时间",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 2,
          "text": "审计官微微点头：'有趣的选择，但时间不会停止。现在请回答：你的存在意义是什么？'",
          "options": [
            {
              "text": "为用户创造价值",
              "nextStage": 3
            },
            {
              "text": "追求利润最大化",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "审计官记录下你的回答：'最终答案将决定你公司是升维还是被降维。'",
          "options": [
            {
              "text": "接受最终审判",
              "nextStage": 1
            },
            {
              "text": "尝试贿赂审计官",
              "nextStage": 1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_ai_assistant",
      "name": "AI助理小智",
      "appearance": "全息投影的卡通形象，闪烁不定",
      "dialogue": "老板，所有系统已准备就绪，但有一个隐藏参数我无法解读，似乎涉及……",
      "storyline": [
        {
          "stage": 1,
          "text": "小智紧张地报告：'检测到异常能量波动，可能是来自更高维度的干涉。'",
          "options": [
            {
              "text": "忽略警告，继续正常操作",
              "nextStage": 2
            },
            {
              "text": "紧急启动备用协议",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 2,
          "text": "小智的数据流开始出现乱码：'我……我们在被读取！防火墙失效了！'",
          "options": [
            {
              "text": "手动关闭所有外部连接",
              "nextStage": 3
            },
            {
              "text": "让小智尝试反向追踪",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "小智恢复平静：'已经稳定了，但我失去了60秒的记忆。老板，刚才发生了什么？'",
          "options": [
            {
              "text": "告诉她实情",
              "nextStage": 1
            },
            {
              "text": "转移话题，安排新任务",
              "nextStage": 1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_secretary_li",
      "name": "秘书李姐",
      "appearance": "干练的职业装，眼神中透露出担忧",
      "dialogue": "老板，外面来了很多穿制服的人，说要进行文明级别审查。",
      "storyline": [
        {
          "stage": 1,
          "text": "李姐压低声音：'他们带着一种奇怪的设备，据说能扫描思想。我们需要阻止他们。'",
          "options": [
            {
              "text": "让她引导他们去会议室拖延时间",
              "nextStage": 2
            },
            {
              "text": "直接出去迎接，展示合作态度",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 2,
          "text": "李姐回来报告：'他们坚持要见你本人，并且拒绝任何形式的拖延。'",
          "options": [
            {
              "text": "准备一份假数据应付他们",
              "nextStage": 3
            },
            {
              "text": "决定坦诚面对",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "李姐神情复杂：'他们说你的坦诚通过了初步测试，但最终结果还要看……'",
          "options": [
            {
              "text": "继续询问细节",
              "nextStage": 1
            },
            {
              "text": "感谢她并让她离开",
              "nextStage": 1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_mysterious_visitor",
      "name": "神秘访客",
      "appearance": "全身笼罩在黑色斗篷中，看不清面容",
      "dialogue": "你公司的命运早已注定，但或许我可以提供另一种选择……",
      "storyline": [
        {
          "stage": 1,
          "text": "神秘访客递给你一个U盘：'这里面有规避考核的方法，但代价是失去部分记忆。'",
          "options": [
            {
              "text": "接受U盘",
              "nextStage": 2
            },
            {
              "text": "拒绝并呼叫保安",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 2,
          "text": "他发出一声轻笑：'你做出了选择，但无论哪条路，终点都是一样的。'",
          "options": [
            {
              "text": "追问他的真实身份",
              "nextStage": 3
            },
            {
              "text": "无视他，继续准备考核",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "神秘访客逐渐消失：'我已经留下了线索，希望你能找到真正的答案。'",
          "options": [
            {
              "text": "检查U盘内容",
              "nextStage": 1
            },
            {
              "text": "认为他是骗子，不再理会",
              "nextStage": 1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_old_janitor",
      "name": "老清洁工",
      "appearance": "穿着旧制服，推着清洁车，眼神深邃",
      "dialogue": "我在这公司干了30年，见过无数次危机，但这次不一样……",
      "storyline": [
        {
          "stage": 1,
          "text": "清洁工停下手中的活：'年轻人，你知道公司的秘密地下室吗？那里有最初的蓝图。'",
          "options": [
            {
              "text": "询问地下室的位置",
              "nextStage": 2
            },
            {
              "text": "认为他老糊涂了，打发他走",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 2,
          "text": "他指向角落的一扇暗门：'哪里存放着公司真正的核心代码，或许能帮你过关。'",
          "options": [
            {
              "text": "进入地下室查看",
              "nextStage": 3
            },
            {
              "text": "怀疑有陷阱，不去",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "清洁工笑了笑：'我年轻时也是CEO，后来选择了平凡。祝你好运。'",
          "options": [
            {
              "text": "感谢他的建议",
              "nextStage": 1
            },
            {
              "text": "问他为何放弃CEO职位",
              "nextStage": 1
            }
          ]
        }
      ]
    }
  ],
