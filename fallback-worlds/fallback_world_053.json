      "name": "典狱长的AI助手",
      "dialogue": "监狱长，检测到多个越狱企图。您还有60秒做出反应。建议立即封锁所有出口。",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "监狱长，检测到多个越狱企图。您还有60秒做出反应。建议立即封锁所有出口。",
          "options": [
            {
              "text": "封锁所有出口。",
              "nextStage": 2
            },
            {
              "text": "放任不管。",
              "nextStage": 3
            }
