          ]
        },
        {
          "stage": 3,
          "dialogue": "授权码正确。有什么需要帮忙的？",
          "options": [
            {
              "text": "关闭东区安全系统。",
              "nextStage": 4
            },
            {
              "text": "带我去控制室。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "dialogue": "东区安全系统已关闭。还有30秒。",
          "options": [
            {
              "text": "谢谢。",
              "nextStage": -1
            },
            {
              "text": "还有其他区域呢？",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "dialogue": "控制室在走廊尽头，但需要指纹识别。",
          "options": [
            {
              "text": "带路。",
              "nextStage": -1
            },
            {
              "text": "我自己去。",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc4",
      "name": "神秘囚犯X",
      "dialogue": "嘘……我知道一条秘密通道，但需要你帮我引开守卫。",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "嘘……我知道一条秘密通道，但需要你帮我引开守卫。",
          "options": [
            {
              "text": "怎么引开？",
              "nextStage": 2
            },
            {
              "text": "我没时间。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "去警报室启动紧急广播，说监狱发生火灾。守卫都会去救火。",
          "options": [
            {
              "text": "好主意，我去。",
              "nextStage": 4
            },
            {
              "text": "太冒险了。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "随你吧，但时间不多了。",
          "options": [
            {
              "text": "好吧，我试试。",
              "nextStage": 2
            },
            {
              "text": "我走另一边。",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 4,
          "dialogue": "干得好！现在跟我来，通道在厨房后面。",
          "options": [
            {
              "text": "跟上。",
              "nextStage": -1
            },
            {
              "text": "你先走，我断后。",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
