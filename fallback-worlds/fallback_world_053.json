  "npcs": [
    {
      "id": "npc1",
      "name": "佐格将军",
      "dialogue": "我是佐格，前星际舰队将军，现在是个囚犯。听着，监狱长，你只有60秒选择：要么帮我越狱，要么死。",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "我是佐格，前星际舰队将军，现在是个囚犯。听着，监狱长，你只有60秒选择：要么帮我越狱，要么死。",
          "options": [
            {
              "text": "帮你越狱，但我要好处。",
              "nextStage": 2
            },
            {
              "text": "我是监狱长，你凭什么命令我？",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "好处？我可以给你一个星球的掌控权，但前提是成功。现在，去控制室关闭所有安全系统。",
          "options": [
            {
              "text": "好，我这就去。",
              "nextStage": 4
            },
            {
              "text": "不，风险太大了。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "看来你选错了。那我只能自己动手了。",
          "options": [
            {
              "text": "别，我改主意了。",
              "nextStage": 2
            },
            {
              "text": "那就来试试。",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 4,
          "dialogue": "很好，你还有45秒。记住，别触发警报。",
          "options": [
            {
              "text": "明白。",
              "nextStage": -1
            },
            {
              "text": "我会小心的。",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "莉娜博士",
      "dialogue": "我是莉娜，监狱的科学家。我发明了一种可以瞬间转移的装置，但需要能量核心。",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "我是莉娜，监狱的科学家。我发明了一种可以瞬间转移的装置，但需要能量核心。",
          "options": [
            {
              "text": "能量核心在哪里？",
              "nextStage": 2
            },
            {
              "text": "我不需要转移装置。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "能量核心在监狱的核心区域，有重兵把守。你需要帮我拿到它。",
          "options": [
            {
              "text": "好，我去拿。",
              "nextStage": 4
            },
            {
              "text": "太危险了，不去。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "那就等死吧。警报一响，我们都完了。",
          "options": [
            {
              "text": "好吧，我改变主意了。",
              "nextStage": 2
            },
            {
              "text": "我还有别的办法。",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 4,
          "dialogue": "给你这个通讯器，拿到后联系我。",
          "options": [
            {
              "text": "好的。",
              "nextStage": -1
            },
            {
              "text": "收到。",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "机器人守卫R-7",
      "dialogue": "检测到异常活动。监狱长，请出示授权码。",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "检测到异常活动。监狱长，请出示授权码。",
          "options": [
            {
              "text": "我是监狱长，不需要授权码。",
              "nextStage": 2
            },
            {
              "text": "授权码是3972。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "违反规定，启动警报。",
          "options": [
            {
              "text": "等等，我有授权码！",
              "nextStage": 1
            },
            {
              "text": "摧毁你！",
              "nextStage": -1
