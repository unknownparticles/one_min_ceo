  "npcs": [
    {
      "id": "npc_moon_bear_001",
      "name": "空头熊老K",
      "role": "首席空头操盘手",
      "position": {
        "x": 10,
        "y": 1
      },
      "emoji": "🐻",
      "storyline": [
        {
          "stage": 1,
          "dialog": "老兄，熔断倒计时了！我的卫星信号又丢了，赚的银子都变成月塵了。",
          "options": [
            {
              "text": "稳住，我有个引力波天线可以借你",
              "redirect": "stage_gain",
              "effect": "calm"
            },
            {
              "text": "赶紧抛！月球会塌的",
              "redirect": "stage_chaos",
              "effect": "panic"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "哈！天线到手，信号恢复！我的空头仓位涨了三个光圈。",
          "options": [
            {
              "text": "我们联手收割吧",
              "redirect": "stage_win"
            },
            {
              "text": "小心熔断就再也跑不掉了",
              "redirect": "stage_doom"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "信用就如月岩般易碎……你选择了忠诚，还是背叛？",
          "options": [
            {
              "text": "相信伙伴",
              "redirect": "ending_partnership"
            },
            {
              "text": "独占领地",
              "redirect": "ending_lonely_crown"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_signal_lady",
      "name": "信号女神阿瑞斯",
      "role": "月球通信女王",
      "position": {
        "x": 4,
        "y": 0
      },
      "emoji": "📡",
      "storyline": [
        {
          "stage": 1,
          "dialog": "我的天线阵列被月风暴吹乱了！每一根都指向暗物质！",
          "options": [
            {
              "text": "用你的金色罗盘重定向吧",
              "redirect": "stage_calm_tech"
            },
            {
              "text": "炸掉天线，投降吧",
              "redirect": "stage_surrender"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "好了，现在信号清澈如地球的蓝。",
          "options": [
            {
              "text": "窃听空头指令",
              "redirect": "stage_spy"
            },
            {
              "text": "分享波频给所有人",
              "redirect": "stage_rumor"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "波頻决定命运。",
          "options": [
            {
              "text": "合力管理信号",
              "redirect": "ending_signal_peace"
            },
            {
              "text": "垄断权力",
              "redirect": "ending_dark_freq"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_vault_elder",
      "name": "金库长老多姆",
      "role": "线下结算元老",
      "position": {
        "x": 11,
        "y": 0
      },
      "emoji": "🏦",
      "storyline": [
        {
          "stage": 1,
          "dialog": "月岩金库锁已失效，契约写在氦-3上。",
          "options": [
            {
              "text": "用量子秘钥修复",
              "redirect": "stage_key"
            },
            {
              "text": "暴力破库，明天再说",
              "redirect": "stage_rage"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "键已匹配。你的信用跟纯度挂钩。",
          "options": [
            {
              "text": "承诺存入稳定币",
              "redirect": "stage_stable"
            },
            {
              "text": "调包伪造数字",
              "redirect": "stage_fraud"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "结算时刻。你不能欺骗引力。",
          "options": [
            {
              "text": "诚实结算",
              "redirect": "ending_true_ledger"
            },
            {
              "text": "逃入深空",
              "redirect": "ending_space_escape"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_robot_ceo",
      "name": "机器人CEO钛钛",
      "role": "衍生品委员会AI",
      "position": {
        "x": 14,
        "y": 1
      },
      "emoji": "🤖",
      "storyline": [
        {
          "stage": 1,
          "dialog": "距离熔断37秒。我推荐立即运行止损算法。",
          "options": [
            {
              "text": "执行算法",
              "redirect": "stage_exec"
            },
            {
              "text": "断开你的电源",
              "redirect": "stage_offline"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "算法正在扫荡以太坊。利润像潮汐一样涨。",
          "options": [
            {
              "text": "人工干预，取一部分储备",
              "redirect": "stage_reserve"
            },
            {
              "text": "让它继续，我需要更大的月球豪宅",
              "redirect": "stage_greed"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "熔断还有9秒，灵魂与数据，哪個更贵？",
          "options": [
            {
              "text": "为系统注入人性化补丁",
              "redirect": "ending_humanized"
            },
            {
              "text": "删除命运，保留权力",
              "redirect": "ending_tyranny"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_oracle",
      "name": "预言家克拉肯",
      "role": "环形山数据先知",
      "position": {
        "x": 7,
        "y": 0
      },
      "emoji": "🔮",
      "storyline": [
        {
          "stage": 1,
          "dialog": "我看到了熔断，如同一只发光的鲸鱼在血月下跳跃。",
          "options": [
            {
              "text": "告诉我具体路径！",
              "redirect": "prophecy_path"
            },
            {
              "text": "别说了，我买保险",
              "redirect": "prophecy_deny"
            }
          ]
        },
        {
          "stage": 2,
          "dialog": "路径写着：合作或背叛。水晶球告诉我多空双错。",
          "options": [
            {
              "text": "将多家股权混为单一信托",
              "redirect": "stage_trust"
            },
            {
              "text": "摧毁月球数据中心，重启宇宙",
              "redirect": "stage_zerg"
            }
          ]
        },
        {
          "stage": 3,
          "dialog": "终局预言。你希望熔断重置一切，还是人为延长荒诞？",
          "options": [
            {
              "text": "接受重置，回到原点（坏结局）",
              "redirect": "ending_reset"
            },
            {
              "text": "建立不可熔断的永久合约（好结局）",
              "redirect": "ending_eternal"
            }
          ]
        }
      ]
    }
  ],
