  "fixedEndings": [
    {
      "id": "ending_partnership",
      "title": "黄金伙伴",
      "description": "你与空头熊老K结成联盟，月光的余晖照着两份黄金合约。熔断延迟，信用疯涨。"
    },
    {
      "id": "ending_lonely_crown",
      "title": "孤月王座",
      "description": "你一意孤行，赶走所有同伴，抱紧所有金砖，却听到交易所最后一个挂单是从你的影子发出的。"
    },
    {
      "id": "ending_signal_peace",
      "title": "频率和平",
      "description": "信号女神分配波频给所有殖民站。交易公平，你的治理得到了月球社区的推崇。"
    },
    {
      "id": "ending_dark_freq",
      "title": "暗域独裁",
      "description": "你垄断了所有通讯波频，市场中一片混沌。熔断只是狂欢的序曲。"
    },
    {
      "id": "ending_true_ledger",
      "title": "真实账本",
      "description": "你选择了诚实结算。这个决定感染了所有人。月球证券世界重启透明纪元。"
    },
    {
      "id": "ending_space_escape",
      "title": "太空流放",
      "description": "你企图卷款逃跑，但逃生舱的导航被黑，你飘向未知的黑洞。一切归零。"
    },
    {
      "id": "ending_humanized",
      "title": "人性算法",
      "description": "你合并了人与AI，活生生的情感被标注在每笔交易之中。熔断也变得慈悲。"
    },
    {
      "id": "ending_tyranny",
      "title": "数字暴君",
      "description": "你删除了世界的情感，只冷酷算法永存。月球被塑造为一台巨型交易机器。孤独至高。"
    }
  ],
  "introText": "月球证券交易所的显示屏撕扯着红光——熔断倒计时 60 秒。你，黄金罗盘的主人，证券大亨，站在环形山大厅的中央。空头、卫星信号、金库秘钥、石英地表，像喜剧般纷杂。深空气压使你心跳加速。只有一个问题：你是月球荒诞里的财神，还是即将粉碎的数据小丑？",
  "ambientMusic": "cyber_lunar_dark",
  "id": "fallback_world_002"
}