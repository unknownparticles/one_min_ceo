              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "印章安全，但你需要它。",
          "options": [
            {
              "text": "再考虑一下。",
              "nextStage": 2
            },
            {
              "text": "离开。",
              "nextStage": 5
            }
          ]
        }
      ]
