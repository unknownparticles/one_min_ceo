  "npcs": [
    {
      "id": "npc1",
      "name": "火星国王",
      "position": [
        7,
        7
      ],
      "dialogue": "爱卿，晚宴的预算...",
      "storyline": [
        {
          "stage": 1,
          "text": "国王威严地看着你，等待你的财务报告。",
          "options": [
            {
              "text": "报告陛下，预算已超额。",
              "nextStage": 2
            },
            {
              "text": "一切尽在掌握。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "国王皱眉，拍案而起。",
          "options": [
            {
              "text": "请求增加拨款。",
              "nextStage": 4
            },
            {
              "text": "承诺缩减开支。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "国王满意地点点头。",
          "options": [
            {
              "text": "提出新的财政计划。",
              "nextStage": 6
            },
            {
              "text": "请求离席处理事务。",
              "nextStage": 7
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "火星王后",
      "position": [
        9,
        5
      ],
      "dialogue": "我的珠宝预算...",
      "storyline": [
        {
          "stage": 1,
          "text": "王后优雅地招手，暗示你靠近。",
          "options": [
            {
              "text": "恭敬地走过去。",
              "nextStage": 2
            },
            {
              "text": "假装没看见。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "王后低声说：'我需要更多火星钻。'",
          "options": [
            {
              "text": "点头答应。",
              "nextStage": 4
            },
            {
              "text": "委婉拒绝。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "王后不满地哼了一声。",
          "options": [
            {
              "text": "回头解释。",
              "nextStage": 4
            },
            {
              "text": "继续走开。",
              "nextStage": 5
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "火星财政部长",
      "position": [
        5,
        10
      ],
      "dialogue": "预算漏洞被发现！",
      "storyline": [
        {
          "stage": 1,
          "text": "财政部长惊慌地跑过来，手里拿着账本。",
          "options": [
            {
              "text": "镇定地接过账本。",
              "nextStage": 2
            },
            {
              "text": "让他冷静。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "账本显示巨额亏空。",
          "options": [
            {
              "text": "撕掉账本（伪造）。",
              "nextStage": 4
            },
            {
              "text": "承认错误。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "部长依然慌乱，引来众人目光。",
          "options": [
            {
              "text": "拉他到角落。",
              "nextStage": 4
            },
            {
              "text": "公开呵斥。",
              "nextStage": 5
            }
          ]
        }
      ]
    },
    {
      "id": "npc4",
      "name": "火星大厨",
      "position": [
        3,
        3
      ],
      "dialogue": "晚宴食材短缺！",
      "storyline": [
        {
          "stage": 1,
          "text": "大厨冲出厨房，满脸焦虑。",
          "options": [
            {
              "text": "询问详情。",
              "nextStage": 2
            },
            {
              "text": "让他找别人。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "大厨说火星龙虾短缺，需要紧急采购。",
          "options": [
            {
              "text": "批准采购。",
              "nextStage": 4
            },
            {
              "text": "拒绝，改用库存。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "大厨失望地离开。",
          "options": [
            {
              "text": "追上去妥协。",
              "nextStage": 4
            },
            {
              "text": "不管了。",
              "nextStage": 5
            }
          ]
        }
      ]
    },
    {
      "id": "npc5",
      "name": "火星侍卫长",
      "position": [
        11,
        2
      ],
      "dialogue": "有刺客混入晚宴！",
      "storyline": [
        {
          "stage": 1,
          "text": "侍卫长低声报告，神色紧张。",
          "options": [
            {
              "text": "立即封锁现场。",
              "nextStage": 2
            },
            {
              "text": "秘密调查。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "侍卫长执行封锁，但引起骚动。",
          "options": [
            {
              "text": "安抚宾客。",
              "nextStage": 4
            },
            {
              "text": "亲自搜捕。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "你决定低调行事。",
          "options": [
            {
              "text": "让侍卫长暗中排查。",
              "nextStage": 4
            },
            {
              "text": "自己悄悄跟踪。",
              "nextStage": 5
            }
          ]
        }
      ]
    },
    {
      "id": "npc6",
      "name": "火星星探",
      "position": [
        13,
        8
      ],
      "dialogue": "想上火星头条吗？",
      "storyline": [
        {
          "stage": 1,
          "text": "星探拿着相机，对你挤眉弄眼。",
          "options": [
            {
              "text": "配合拍照。",
              "nextStage": 2
            },
            {
              "text": "拒绝并赶走。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "星探拍了几张，说头条见。",
          "options": [
            {
              "text": "贿赂他不要发。",
              "nextStage": 4
            },
            {
              "text": "无所谓。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "星探悻悻离开，但偷拍了一张。",
          "options": [
            {
              "text": "追回相机。",
              "nextStage": 4
            },
            {
              "text": "由他去吧。",
              "nextStage": 5
            }
          ]
        }
      ]
    }
  ],
