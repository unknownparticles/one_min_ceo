              "nextStage": 4
            },
            {
              "text": "保留证据。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "国王差点喝下，你急忙阻止。",
          "options": [
            {
              "text": "承认错误。",
              "nextStage": 4
            },
            {
              "text": "嫁祸他人。",
              "nextStage": 5
            }
          ]
        }
