      "storyline": [
        {
          "stage": 1,
          "text": "一张财务报表落在角落。",
          "options": [
            {
              "text": "捡起它。",
              "nextStage": 2
            },
            {
              "text": "踩住它。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "报表显示你的财务操作有问题。",
          "options": [
