            {
              "text": "归还王后。",
              "nextStage": 4
            },
            {
              "text": "私藏起来。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "项链被踩脏，可能惹怒王后。",
          "options": [
