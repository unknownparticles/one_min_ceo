          "stage": 1,
          "text": "一个通讯器在震动，有消息。",
          "options": [
            {
              "text": "查看消息。",
              "nextStage": 2
            },
            {
              "text": "关机。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "消息显示地球盟友有紧急情况。",
