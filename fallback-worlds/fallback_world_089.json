  "fixedEndings": [
    {
      "id": "ending1",
      "condition": "玩家在晚宴开始前未能解决预算问题",
      "text": "国王在晚宴上公开指责你，你被当场解职。"
    },
    {
      "id": "ending2",
      "condition": "玩家成功从火星金库中取出资金填补亏空",
      "text": "你化解了财务危机，国王赏赐你火星勋章。"
    },
    {
      "id": "ending3",
      "condition": "玩家被王后陷害，被发现私藏项链",
      "text": "王后指控你盗窃，你被关进火星监狱。"
    },
    {
      "id": "ending4",
      "condition": "玩家抓住刺客，保护了皇室安全",
      "text": "国王感激你的忠诚，提升你为财务首相。"
    },
    {
      "id": "ending5",
      "condition": "玩家销毁财务报表并掩盖真相",
      "text": "你暂时安全，但财政漏洞迟早会暴露，你开始逃亡。"
    },
    {
      "id": "ending6",
      "condition": "玩家与地球盟友通讯并背叛火星",
      "text": "你与地球合作，颠覆火星王朝，成为新政权财务官。"
    },
    {
      "id": "ending7",
      "condition": "玩家透露毒酒阴谋，但被凶手灭口",
      "text": "你发现了秘密，但被暗杀，晚宴变成你的葬礼。"
    },
    {
      "id": "ending8",
      "condition": "玩家利用印章伪造文件，被揭穿",
      "text": "伪造暴露，你被处以流放火星荒漠。"
