  "npcs": [
    {
      "id": "npc_1",
      "name": "财务总监",
      "dialogue": "上市钟声即将敲响！",
      "storyline": [
        {
          "stage": 1,
          "text": "财务总监慌张地说：我们账上有个黑洞，快想办法！",
          "options": [
            {
              "text": "把黑洞包装成资产",
              "nextStage": 2,
              "effect": "finance_1"
            },
            {
              "text": "承认错误，推迟上市",
              "nextStage": 3,
              "effect": "finance_2"
            }
          ]
        },
        {
          "stage": 2,
          "text": "你决定将黑洞包装成无限能源资产。财务总监擦汗：这样真的行吗？",
          "options": [
            {
              "text": "没问题，投资者喜欢故事",
              "nextStage": 4,
              "effect": "story_good"
            },
            {
              "text": "还是再考虑一下",
              "nextStage": 1,
              "effect": "back"
            }
          ]
        },
        {
          "stage": 3,
          "text": "你决定推迟上市，但董事会震怒。",
          "options": [
            {
              "text": "争取董事会支持",
              "nextStage": 5,
              "effect": "board_1"
            },
            {
              "text": "辞职不干",
              "nextStage": 6,
              "effect": "quit"
            }
          ]
        },
        {
          "stage": 4,
          "text": "投资者被故事吸引，股价飙升！",
          "options": [
            {
              "text": "继续吹嘘",
              "nextStage": 7,
              "effect": "success"
            },
            {
              "text": "见好就收",
              "nextStage": 8,
              "effect": "caution"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_2",
      "name": "首席科学家",
      "dialogue": "黑洞正在吞噬数据！",
      "storyline": [
        {
          "stage": 1,
          "text": "科学家：黑洞AI失控了，它开始吃掉服务器数据！",
          "options": [
            {
              "text": "关闭AI",
              "nextStage": 2,
              "effect": "ai_off"
