              "text": "隐瞒真相",
              "nextStage": 5,
              "effect": "hide"
            }
          ]
        },
        {
          "stage": 3,
          "text": "AI疯狂吞噬，系统即将崩溃。",
          "options": [
            {
              "text": "紧急重启",
              "nextStage": 6,
              "effect": "restart"
