            {
              "text": "让它继续吃，也许能优化数据",
              "nextStage": 3,
              "effect": "ai_continue"
            }
          ]
        },
        {
          "stage": 2,
          "text": "AI关闭，但核心数据已损毁。",
          "options": [
            {
              "text": "用备份恢复",
              "nextStage": 4,
              "effect": "backup"
