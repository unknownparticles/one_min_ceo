  "fixedEndings": [
    {
      "id": "ending1",
      "text": "你用备用王冠完成了仪式，但失去了威信。"
    },
    {
      "id": "ending2",
      "text": "强攻导致星际战争，帝国陷入战火。"
    },
    {
      "id": "ending3",
      "text": "战斗爆发，你英勇牺牲。"
    },
    {
      "id": "ending4",
      "text": "你严惩了侍从，但宝石被毁，仪式失败。"
    },
    {
      "id": "ending5",
      "text": "你背信弃义，海盗报复，帝国动荡。"
    },
    {
      "id": "ending6",
      "text": "宰相被捕，余党潜伏，危机四伏。"
    },
    {
      "id": "ending7",
      "text": "你揭露了外星阴谋，成为英雄。"
    },
    {
      "id": "ending8",
      "text": "接纳海盗，但帝国声誉受损。"
    },
    {
      "id": "ending9",
      "text": "奖励侍从，他成为忠臣。"
    },
    {
      "id": "ending10",
      "text": "放走侍从，他感恩戴德。"
    },
    {
      "id": "ending11",
      "text": "仪式圆满，帝国繁荣。"
    },
    {
      "id": "ending12",
      "text": "宰相成为你最信任的人。"
    },
    {
      "id": "ending13",
      "text": "你怀疑宰相，导致君臣不和。"
    },
    {
      "id": "ending14",
      "text": "成功捕获外星间谍，帝国安全。"
    },
    {
      "id": "ending15",
      "text": "计划败露，你被暗杀。"
    },
    {
      "id": "ending16",
      "text": "你暗算海盗，但失去信誉。"
    },
    {
      "id": "ending17",
      "text": "你遵守诺言，海盗成为盟友。"
    },
    {
      "id": "ending18",
      "text": "人质受伤，你愧疚不已。"
    },
    {
      "id": "ending19",
      "text": "继续战斗，最终同归于尽。"
    },
    {
      "id": "ending20",
      "text": "包围海盗，成功夺回王冠。"
    },
    {
      "id": "ending21",
      "text": "被识破，海盗撕票。"
    },
    {
      "id": "ending22",
      "text": "放走海盗，他们销声匿迹。"
    },
    {
      "id": "ending23",
      "text": "背信弃义，引发仇恨。"
    },
    {
      "id": "ending24",
      "text": "动用备用王冠，仪式继续。"
    },
    {
      "id": "ending25",
      "text": "暴怒攻击，双方伤亡惨重。"
    },
    {
      "id": "ending26",
      "text": "仪式继续，但诅咒降临。"
    },
    {
      "id": "ending27",
      "text": "用替身，你躲过一劫。"
    },
    {
      "id": "ending28",
      "text": "无视诅咒，但灾祸不断。"
    },
    {
      "id": "ending29",
      "text": "相信护卫，但内奸得逞。"
    },
    {
      "id": "ending30",
      "text": "重整秩序，但元气大伤。"
    },
    {
      "id": "ending31",
      "text": "你退位，帝国进入新纪元。"
    },
    {
      "id": "ending32",
      "text": "奖励法师，他成为国师。"
    },
    {
      "id": "ending33",
      "text": "继续仪式，一切顺利。"
    },
    {
      "id": "ending34",
      "text": "联姻成功，帝国与外星结盟。"
    },
    {
      "id": "ending35",
      "text": "御驾亲征，你战死沙场。"
    },
    {
      "id": "ending36",
      "text": "任命元帅，帝国获胜。"
    },
    {
      "id": "ending37",
      "text": "镇压民众，失去民心。"
    },
    {
      "id": "ending38",
      "text": "解释后，民众理解。"
    },
    {
      "id": "ending39",
      "text": "成功捕获刺客，安全加冕。"
    },
    {
      "id": "ending40",
      "text": "计划失败，你被刺杀。"
    },
    {
      "id": "ending41",
      "text": "处决可疑人物，但错杀好人。"
    },
    {
      "id": "ending42",
      "text": "感谢侍卫长，晋升他。"
    },
    {
      "id": "ending43",
      "text": "逮捕宰相，清除内患。"
    },
    {
      "id": "ending44",
      "text": "放长线，却让大鱼跑了。"
    },
    {
      "id": "ending45",
      "text": "仪式因王冠瑕疵而不完美。"
    },
    {
      "id": "ending46",
      "text": "你戴上王冠，成为全宇宙的焦点。"
    },
    {
      "id": "ending47",
      "text": "交给侍从，但他卷款潜逃。"
    },
    {
      "id": "ending48",
      "text": "你前往未知星系，发现新大陆。"
    },
    {
      "id": "ending49",
      "text": "报告帝国，但被官僚耽误。"
    },
    {
      "id": "ending50",
      "text": "销毁地图，你失去了机遇。"
    },
    {
      "id": "ending51",
      "text": "听天由命，帝国灭亡。"
    },
    {
      "id": "ending52",
      "text": "嘉奖功臣，人心所向。"
    },
    {
      "id": "ending53",
      "text": "独揽功劳，引起不满。"
    },
    {
      "id": "ending54",
      "text": "平乱成功，但代价巨大。"
    },
    {
      "id": "ending55",
      "text": "逃亡途中，你被俘。"
    },
    {
      "id": "ending56",
      "text": "销毁毒药，救了别人一命。"
    },
    {
      "id": "ending57",
      "text": "留着害人，最终自食其果。"
    },
    {
      "id": "ending58",
      "text": "逮捕刺客，仪式安全。"
    },
    {
      "id": "ending59",
      "text": "将计就计，揪出幕后黑手。"
    },
    {
      "id": "ending60",
      "text": "无所谓，你失去了超能力的机会。"
    },
    {
      "id": "ending61",
      "text": "彻底遗忘，过平凡的一生。"
    },
    {
      "id": "ending62",
      "text": "重建仪式，帝国新气象。"
    },
    {
      "id": "ending63",
      "text": "抵抗到底，壮烈牺牲。"
    },
    {
