  "npcs": [
    {
      "id": "npc1",
      "name": "帝国宰相",
      "x": 4,
      "y": 3,
      "storyline": [
        {
          "stage": 1,
          "text": "摄政王，仪式即将开始，但王冠上的一颗宝石被窃了。",
          "options": [
            {
              "text": "下令全城搜查",
              "nextStage": 2
            },
            {
              "text": "询问他怀疑谁",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "搜查令已发出，但时间紧迫，可能来不及。",
          "options": [
            {
              "text": "使用备用王冠",
              "nextStage": 4
            },
            {
              "text": "亲自去追查",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "宰相低声说：我怀疑是星际海盗所为，他们可能藏在废弃空间站。",
          "options": [
            {
              "text": "派兵围剿",
              "nextStage": 6
            },
            {
              "text": "假装不知，暗中调查",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "备用王冠虽然朴素，但足够应付仪式。",
          "options": [
            {
              "text": "接受备用王冠",
              "nextStage": "ending1"
            },
            {
              "text": "坚持找回原王冠",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "你决定亲自追查，但时间只剩30秒。",
          "options": [
            {
              "text": "去空间站搜查",
              "nextStage": 8
            },
            {
              "text": "审问宫廷人员",
              "nextStage": 9
            }
          ]
        },
        {
          "stage": 6,
          "text": "舰队出发，但可能引发外交冲突。",
          "options": [
            {
              "text": "不顾后果，强攻",
              "nextStage": "ending2"
            },
            {
              "text": "先谈判",
              "nextStage": 10
            }
          ]
        },
        {
          "stage": 7,
          "text": "你暗中调查，发现宰相形迹可疑。",
          "options": [
            {
              "text": "直接质问宰相",
              "nextStage": 11
            },
            {
              "text": "继续跟踪",
              "nextStage": 12
            }
          ]
        },
        {
          "stage": 8,
          "text": "在空间站找到了海盗，但他们要求谈判。",
          "options": [
            {
              "text": "同意谈判",
              "nextStage": 13
            },
            {
              "text": "直接开战",
              "nextStage": "ending3"
            }
          ]
        },
        {
          "stage": 9,
          "text": "审问下，一名侍从承认偷了宝石。",
          "options": [
            {
              "text": "饶恕他",
              "nextStage": 14
            },
            {
              "text": "严惩不贷",
              "nextStage": "ending4"
            }
          ]
        },
        {
          "stage": 10,
          "text": "谈判成功，海盗交还宝石，但要求赦免。",
          "options": [
            {
              "text": "赦免他们",
              "nextStage": 15
            },
            {
              "text": "先拿宝石，再翻脸",
              "nextStage": "ending5"
            }
          ]
        },
        {
          "stage": 11,
          "text": "宰相惊慌失措，承认是他监守自盗。",
          "options": [
            {
              "text": "逮捕宰相",
              "nextStage": "ending6"
            },
            {
              "text": "给他一个机会",
              "nextStage": 16
            }
          ]
        },
        {
          "stage": 12,
          "text": "你发现宰相与外星势力勾结。",
          "options": [
            {
              "text": "揭露阴谋",
              "nextStage": "ending7"
            },
            {
              "text": "将计就计",
              "nextStage": 17
            }
          ]
        },
        {
          "stage": 13,
          "text": "海盗同意归还宝石，但要求加入帝国。",
          "options": [
            {
              "text": "接纳他们",
              "nextStage": "ending8"
            },
            {
              "text": "拒绝并开战",
              "nextStage": "ending3"
            }
          ]
        },
        {
          "stage": 14,
          "text": "侍从感激涕零，交出宝石。",
          "options": [
            {
              "text": "奖励他",
              "nextStage": "ending9"
            },
            {
              "text": "放他走",
              "nextStage": "ending10"
            }
          ]
        },
        {
          "stage": 15,
          "text": "海盗成为帝国盟友，仪式顺利进行。",
          "options": [
            {
              "text": "圆满结束",
              "nextStage": "ending11"
            }
          ]
        },
        {
          "stage": 16,
          "text": "宰相感激不尽，发誓效忠。",
          "options": [
            {
              "text": "信任他",
              "nextStage": "ending12"
            },
            {
              "text": "仍心存疑虑",
              "nextStage": "ending13"
            }
          ]
        },
        {
          "stage": 17,
          "text": "你将计就计，设下陷阱。",
          "options": [
            {
              "text": "成功捕获外星间谍",
              "nextStage": "ending14"
            },
            {
              "text": "计划败露",
              "nextStage": "ending15"
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "星际海盗头目",
      "x": 2,
      "y": 7,
      "storyline": [
        {
          "stage": 1,
          "text": "哈哈，摄政王，你的王冠在我手中！",
          "options": [
            {
              "text": "威胁他",
              "nextStage": 2
            },
            {
              "text": "谈判",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "你以为我会怕？我有人质！",
          "options": [
            {
              "text": "妥协",
              "nextStage": 4
            },
            {
              "text": "强攻",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "我们可以谈谈条件。",
          "options": [
            {
              "text": "问条件",
              "nextStage": 6
            },
            {
              "text": "假装同意",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "你答应了？好，放人。",
          "options": [
            {
              "text": "暗算他",
              "nextStage": "ending16"
            },
            {
              "text": "遵守诺言",
              "nextStage": "ending17"
            }
          ]
        },
        {
          "stage": 5,
          "text": "强攻失败，人质受伤。",
          "options": [
            {
              "text": "懊悔",
              "nextStage": "ending18"
            },
            {
              "text": "继续战斗",
              "nextStage": "ending19"
            }
          ]
        },
        {
          "stage": 6,
          "text": "条件：给我们一艘星舰和赦免。",
          "options": [
            {
              "text": "答应",
              "nextStage": 8
            },
            {
              "text": "拒绝",
              "nextStage": 9
            }
          ]
        },
        {
          "stage": 7,
          "text": "你假装同意，但暗中调动军队。",
          "options": [
            {
              "text": "包围他们",
              "nextStage": "ending20"
            },
            {
              "text": "被识破",
              "nextStage": "ending21"
            }
          ]
        },
        {
          "stage": 8,
          "text": "海盗满意，归还王冠。",
          "options": [
            {
              "text": "放他们走",
              "nextStage": "ending22"
            },
            {
              "text": "背信弃义",
              "nextStage": "ending23"
            }
          ]
        },
        {
          "stage": 9,
          "text": "海盗恼羞成怒，摧毁王冠。",
          "options": [
            {
              "text": "动用备用",
              "nextStage": "ending24"
            },
            {
              "text": "暴怒攻击",
              "nextStage": "ending25"
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "宫廷法师",
      "x": 10,
      "y": 4,
      "storyline": [
        {
          "stage": 1,
          "text": "殿下，星象显示今天不宜加冕。",
          "options": [
            {
              "text": "推迟仪式",
              "nextStage": 2
            },
            {
              "text": "不信邪",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "推迟会引发政局动荡。",
          "options": [
            {
              "text": "强行举行",
              "nextStage": 4
            },
            {
              "text": "寻求其他建议",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "你不信，但法师坚持。",
          "options": [
            {
              "text": "驱赶法师",
              "nextStage": 6
            },
            {
              "text": "听他解释",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "仪式开始，天空出现异象。",
          "options": [
            {
              "text": "停止仪式",
              "nextStage": 8
            },
            {
              "text": "继续",
              "nextStage": "ending26"
            }
          ]
        },
        {
          "stage": 5,
          "text": "法师建议用替身。",
          "options": [
            {
              "text": "采纳",
              "nextStage": "ending27"
            },
            {
              "text": "拒绝",
              "nextStage": 4
            }
          ]
        },
        {
          "stage": 6,
          "text": "法师被驱赶，但留下诅咒。",
          "options": [
            {
              "text": "无视",
              "nextStage": "ending28"
            },
            {
              "text": "追回法师",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 7,
          "text": "法师说：有内奸在仪式上。",
          "options": [
            {
              "text": "彻查",
              "nextStage": 9
            },
            {
              "text": "相信护卫",
              "nextStage": "ending29"
            }
          ]
        },
        {
          "stage": 8,
          "text": "仪式中断，帝国陷入混乱。",
          "options": [
            {
              "text": "重整秩序",
              "nextStage": "ending30"
            },
            {
              "text": "退位",
              "nextStage": "ending31"
            }
          ]
        },
        {
          "stage": 9,
          "text": "内奸被抓，仪式安全。",
          "options": [
            {
              "text": "奖励法师",
              "nextStage": "ending32"
            },
            {
              "text": "继续仪式",
              "nextStage": "ending33"
            }
          ]
        }
      ]
    },
