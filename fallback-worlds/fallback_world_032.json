  "npcs": [
    {
      "id": "npc1",
      "name": "遗迹守护者",
      "dialogue": "凡人，你为何打扰神明长眠？",
      "storyline": [
        {
          "stage": 1,
          "text": "守护者双眼放光，声音如雷鸣。",
          "options": [
            {
              "text": "我是来考古的，并无恶意。",
              "nextStage": 2
            },
            {
              "text": "神明已死，我来接管遗产。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "守护者稍微缓和，但依然警惕。",
          "options": [
            {
              "text": "告诉我神明的秘密。",
              "nextStage": 4
            },
            {
              "text": "我要怎么离开这里？",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "守护者愤怒，周围开始震动。",
          "options": [
            {
              "text": "我道歉，请息怒。",
              "nextStage": 2
            },
            {
              "text": "战斗吧！",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "守护者低语，透露了神明的弱点。",
          "options": [
            {
              "text": "谢谢，我会小心使用。",
              "nextStage": 5
            },
            {
              "text": "太好了，我要征服这里。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 5,
          "text": "对话结束，守护者消失。",
          "options": [
            {
              "text": "继续探索。",
              "nextStage": -1
            },
            {
              "text": "返回营地。",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "考古队员小红",
      "dialogue": "会长！这里有奇怪的符号！",
      "storyline": [
        {
          "stage": 1,
          "text": "小红指着墙上的发光符号。",
          "options": [
            {
              "text": "让我看看。",
              "nextStage": 2
            },
            {
              "text": "别碰，可能有危险。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "符号突然激活，投射出全息影像。",
          "options": [
            {
              "text": "记录影像。",
              "nextStage": 4
            },
            {
              "text": "关闭它！",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "符号熄灭，但地面开始震动。",
          "options": [
            {
              "text": "撤离！",
              "nextStage": 5
            },
            {
              "text": "继续调查。",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 4,
          "text": "影像显示神明创造宇宙的片段。",
          "options": [
            {
              "text": "太震撼了，继续播放。",
              "nextStage": 5
            },
            {
              "text": "保存并分享给团队。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "影像结束，小红获得新线索。",
          "options": [
            {
              "text": "去下一个地点。",
              "nextStage": -1
            },
            {
              "text": "研究符号含义。",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "神秘商人",
      "dialogue": "我有你需要的道具，但代价是什么？",
      "storyline": [
        {
          "stage": 1,
          "text": "一个黑影在角落招手。",
          "options": [
            {
              "text": "你有什么？",
              "nextStage": 2
            },
            {
              "text": "我不信任你。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "商人展示古老护符。",
          "options": [
            {
              "text": "怎么换？",
              "nextStage": 4
            },
            {
              "text": "太贵了，不要。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "商人冷笑，消失在黑暗中。",
          "options": [
            {
              "text": "后悔，追上去。",
              "nextStage": 2
            },
            {
              "text": "算了，继续前进。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "商人要你的一半考古成果。",
          "options": [
            {
              "text": "成交。",
              "nextStage": 5
            },
            {
              "text": "不行，这是我的使命。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 5,
          "text": "交易完成，获得护符。",
          "options": [
            {
              "text": "装备护符。",
              "nextStage": -1
            },
            {
              "text": "继续探索。",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc4",
      "name": "神明的回音",
      "dialogue": "宇宙的真相，你承受得起吗？",
      "storyline": [
        {
          "stage": 1,
          "text": "一个虚无的声音在脑海中响起。",
          "options": [
            {
              "text": "告诉我。",
              "nextStage": 2
            },
            {
              "text": "我不想听。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "声音揭示宇宙起源的真相。",
          "options": [
            {
              "text": "这太疯狂了。",
              "nextStage": 4
            },
            {
              "text": "我来此就是为了这个。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "声音消失，但留下诅咒。",
          "options": [
            {
              "text": "解除诅咒。",
              "nextStage": 4
            },
            {
              "text": "无视它。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "真相让玩家疯狂。",
          "options": [
            {
              "text": "保持冷静。",
              "nextStage": 5
            },
            {
              "text": "接受疯狂获得力量。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "回音消散，玩家获得新能力。",
          "options": [
            {
              "text": "使用能力。",
              "nextStage": -1
            },
            {
              "text": "继续探索。",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc5",
      "name": "时间旅行者",
      "dialogue": "60秒后遗迹将坍塌！",
      "storyline": [
        {
          "stage": 1,
          "text": "一个穿着未来服装的人冲过来。",
          "options": [
            {
              "text": "什么？怎么办？",
              "nextStage": 2
            },
            {
              "text": "你是真的吗？",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "旅行者给你一个传送装置。",
          "options": [
            {
              "text": "谢谢！如何使用？",
              "nextStage": 4
            },
            {
              "text": "我不信，这是陷阱。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "旅行者消失，但留下警告。",
          "options": [
            {
              "text": "相信他，准备撤离。",
              "nextStage": 4
            },
            {
              "text": "继续探索，忽略警告。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "传送装置启动，可以瞬间移动。",
          "options": [
            {
              "text": "传送到安全区。",
              "nextStage": 5
            },
            {
              "text": "传送到宝藏室。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "时间旅行者完成任务，消失。",
          "options": [
            {
              "text": "感谢他。",
              "nextStage": -1
            },
            {
              "text": "继续考古。",
              "nextStage": -1
            }
          ]
        }
      ]
    }
  ],
