      "name": "星际科技CEO",
      "title": "路演主讲人",
      "avatar": "ceo",
      "storyline": [
        {
          "stage": 0,
          "dialogue": "年轻人，你来了！距离IPO只剩60秒，我需要你帮我稳住局面。",
          "options": [
            {
              "text": "放心，交给我！",
              "nextStage": 1,
              "effect": {
                "reputation": 10
              }
            },
            {
              "text": "我尽力……但不太有把握。",
              "nextStage": 1,
              "effect": {
                "reputation": 5
              }
            }
