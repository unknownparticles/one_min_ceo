  "npcs": [
    {
      "id": "npc_01",
      "name": "星云资本代表",
      "position": {
        "x": 4,
        "y": 1
      },
      "dialogue": "你好，我是来自仙女座的星云资本代表。",
      "storyline": [
        {
          "stage": 0,
          "title": "初次接触",
          "dialogue": "人类投资者，我们带来了最新的金融技术。",
          "options": [
            {
              "text": "展示你们的方案",
              "nextStage": 1
            },
            {
              "text": "我对此有疑虑",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "title": "技术展示",
          "dialogue": "我们的量子对冲基金能在0.01秒内完成一笔交易。",
          "options": [
            {
              "text": "合作愉快",
              "nextStage": -1
            },
            {
              "text": "我需要更多时间考虑",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 2,
          "title": "疑虑",
          "dialogue": "您对跨星系金融风险有担忧？",
          "options": [
            {
              "text": "是的，风险太大",
              "nextStage": -1
            },
            {
              "text": "不，只是好奇",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_02",
      "name": "猎户座风险投资人",
      "position": {
        "x": 8,
        "y": 2
      },
      "dialogue": "我是猎户座风险投资人，寻找下一个星际独角兽。",
      "storyline": [
        {
          "stage": 0,
          "title": "投资意向",
          "dialogue": "听说你们地球初创公司很有潜力。",
          "options": [
            {
              "text": "我们正在开发反重力技术",
              "nextStage": 1
            },
            {
              "text": "我们专注AI芯片",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "title": "反重力",
          "dialogue": "反重力技术？那可是热门领域。",
          "options": [
            {
              "text": "需要融资5000万",
              "nextStage": -1
            },
            {
              "text": "先看看您的投资组合",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 2,
          "title": "AI芯片",
          "dialogue": "AI芯片竞争激烈，但回报可观。",
          "options": [
            {
              "text": "我们有独特架构",
              "nextStage": -1
            },
            {
              "text": "我们需要战略伙伴",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_03",
      "name": "仙女座中央银行行长",
      "position": {
        "x": 3,
        "y": 3
      },
      "dialogue": "我代表仙女座中央银行，负责星际货币政策。",
      "storyline": [
        {
          "stage": 0,
          "title": "货币政策",
          "dialogue": "跨星系资本流动需要新的货币框架。",
          "options": [
            {
              "text": "支持数字货币结算",
              "nextStage": 1
            },
            {
              "text": "反对金融干预",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "title": "数字货币",
          "dialogue": "我们将发行星系稳定币，与黄金挂钩。",
          "options": [
            {
              "text": "我们愿意试点",
              "nextStage": -1
            },
            {
              "text": "我需要更多细节",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 2,
          "title": "反对",
          "dialogue": "金融干预可能会破坏本地经济。",
          "options": [
            {
              "text": "但我们需要监管",
              "nextStage": -1
            },
            {
              "text": "让我们寻求折中方案",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_04",
      "name": "天琴座天使投资人",
      "position": {
        "x": 10,
        "y": 3
      },
      "dialogue": "我是天琴座的天使投资人，专投早期星际创业公司。",
      "storyline": [
        {
          "stage": 0,
          "title": "天使投资",
          "dialogue": "你们有没有颠覆性的想法？",
          "options": [
            {
              "text": "我们有太空电梯计划",
              "nextStage": 1
            },
            {
              "text": "我们在做火星房地产",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "title": "太空电梯",
          "dialogue": "太空电梯！那是改变游戏规则的技术。",
          "options": [
            {
              "text": "需要种子轮1000万",
              "nextStage": -1
            },
            {
              "text": "我们可以提供原型",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 2,
          "title": "火星房地产",
          "dialogue": "火星房地产？有点早期，但潜力巨大。",
          "options": [
            {
              "text": "我们已有土地所有权",
              "nextStage": -1
            },
            {
              "text": "需要合作伙伴开发",
              "nextStage": -1
            }
          ]
        }
      ]
    },
    {
      "id": "npc_05",
      "name": "双鱼星系并购顾问",
      "position": {
        "x": 6,
        "y": 4
      },
      "dialogue": "我来自双鱼星系，专门从事跨星系并购。",
      "storyline": [
        {
          "stage": 0,
          "title": "并购提议",
          "dialogue": "我们注意到贵公司在银河系的扩张计划。",
          "options": [
            {
              "text": "我们正在寻找收购目标",
              "nextStage": 1
            },
            {
              "text": "我们打算保持独立",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "title": "收购目标",
          "dialogue": "我们推荐收购半人马座的一家AI公司。",
          "options": [
            {
              "text": "请提供详细资料",
              "nextStage": -1
            },
            {
              "text": "估值是多少？",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 2,
          "title": "独立",
          "dialogue": "独立发展也是不错的选择，但我们仍可合作。",
          "options": [
            {
              "text": "好吧，我们谈谈战略合作",
              "nextStage": -1
            },
            {
              "text": "不，谢谢",
              "nextStage": -1
            }
          ]
        }
      ]
    }
