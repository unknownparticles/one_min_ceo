  "npcs": [
    {
      "id": "npc_1",
      "name": "神秘竞拍者",
      "role": "竞争对手",
      "dialogue": "你不可能赢的！",
      "personality": "傲慢",
      "storyline": [
        {
          "stage": 1,
          "text": "神秘竞拍者轻蔑地看着你。",
          "options": [
            {
              "text": "无视他",
              "nextStage": 2
            },
            {
              "text": "回击",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "他冷笑一声，转身离开。",
          "options": [
            {
              "text": "跟上他",
              "nextStage": 4
            },
            {
              "text": "继续准备",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "你嘲讽他，他愤怒地握紧拳头。",
          "options": [
            {
              "text": "挑衅他",
              "nextStage": 4
            },
            {
              "text": "道歉",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 4,
          "text": "你们对峙，气氛紧张。",
          "options": [
            {
              "text": "动手",
              "nextStage": 5
            },
            {
              "text": "冷静",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "他最终离开，但敌意未消。",
          "options": [
            {
              "text": "警惕他",
              "nextStage": -1
            },
            {
              "text": "忽略他",
              "nextStage": -1
            }
          ]
        }
      ]
    },
