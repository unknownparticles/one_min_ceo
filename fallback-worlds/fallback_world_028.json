  "npcs": [
    {
      "name": "列车长",
      "role": "资深调度员",
      "storyline": [
        {
          "stage": 1,
          "text": "总经理！列车引擎过热，冷却系统失效！",
          "options": [
            {
              "text": "启动备用冷却剂",
              "nextStage": 2
            },
            {
              "text": "检查引擎数据",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "备用冷却剂已注入，但压力不足！",
          "options": [
            {
              "text": "手动增压",
              "nextStage": 4
            },
            {
              "text": "呼叫维修机器人",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "数据显示主冷却泵损坏，需要紧急更换。",
          "options": [
            {
              "text": "亲自去更换",
              "nextStage": 6
            },
            {
              "text": "派遣维修组",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "手动增压成功，温度下降中。但可能会触发安全警报。",
          "options": [
            {
              "text": "忽略警报继续运行",
              "nextStage": 8
            },
            {
              "text": "重置警报系统",
              "nextStage": 9
            }
          ]
        },
        {
          "stage": 5,
          "text": "维修机器人响应，但需要5分钟到达。",
          "options": [
            {
              "text": "等待机器人",
              "nextStage": 10
            },
            {
              "text": "尝试其他方法",
              "nextStage": 11
            }
          ]
        },
        {
          "stage": 6,
          "text": "你冲向引擎室，但时间紧迫！",
          "options": [
            {
              "text": "加速奔跑",
              "nextStage": 12
            },
            {
              "text": "用对讲机指挥",
              "nextStage": 13
            }
          ]
        },
        {
          "stage": 7,
          "text": "维修组已出发，但他们被困在3号车厢。",
          "options": [
            {
              "text": "前往3号车厢救援",
              "nextStage": 14
            },
            {
              "text": "派无人机协助",
              "nextStage": 15
            }
          ]
        },
        {
          "stage": 8,
          "text": "安全警报引发恐慌，乘客开始骚乱。",
          "options": [
            {
              "text": "广播安抚",
              "nextStage": 16
            },
            {
              "text": "出动安保",
              "nextStage": 17
            }
          ]
        }
      ]
    },
    {
      "name": "人工智能AI",
      "role": "系统管家",
      "storyline": [
        {
          "stage": 1,
          "text": "检测到时空扭曲异常，列车可能偏离轨道。",
          "options": [
            {
              "text": "紧急停靠最近站台",
              "nextStage": 2
            },
            {
              "text": "尝试修正轨道",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "最近站台是量子车站，但已废弃！",
          "options": [
            {
              "text": "冒险停靠",
              "nextStage": 4
            },
            {
              "text": "继续前行寻找安全站",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "轨道修正需要能量，但可能耗尽备用电源。",
          "options": [
            {
              "text": "牺牲空调系统供电",
              "nextStage": 6
            },
            {
              "text": "使用应急反应堆",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "停靠成功，但发现站台有未知生物。",
          "options": [
            {
              "text": "武装应对",
              "nextStage": 8
            },
            {
              "text": "尝试沟通",
              "nextStage": 9
            }
          ]
        },
        {
          "stage": 5,
          "text": "前方发现时空裂缝，列车可能被吸入。",
          "options": [
            {
              "text": "紧急转向",
              "nextStage": 10
            },
            {
              "text": "加速冲过",
              "nextStage": 11
            }
          ]
        }
      ]
    },
    {
      "name": "机械师",
      "role": "维修专家",
      "storyline": [
        {
          "stage": 1,
          "text": "引擎室发现炸弹！还有30秒爆炸！",
          "options": [
            {
              "text": "尝试拆除",
              "nextStage": 2
            },
            {
              "text": "将炸弹丢出列车",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "拆除需要密码，但密码未知。",
          "options": [
            {
              "text": "猜密码",
              "nextStage": 4
            },
            {
              "text": "使用紧急切断",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "打开气闸需要授权，时间不够！",
          "options": [
            {
              "text": "强行开启",
              "nextStage": 6
            },
            {
              "text": "寻找备用通道",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "猜错！炸弹提前爆炸。",
          "options": [
            {
              "text": "跑向紧急出口",
              "nextStage": 8
            },
            {
              "text": "躲入防护舱",
              "nextStage": 9
            }
          ]
        }
      ]
    },
    {
      "name": "乘务长",
      "role": "乘客安抚",
      "storyline": [
        {
          "stage": 1,
          "text": "乘客恐慌，有人试图打开紧急车门。",
          "options": [
            {
              "text": "强制制止",
              "nextStage": 2
            },
            {
              "text": "解释情况",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "制止引发冲突，多人受伤。",
          "options": [
            {
              "text": "呼叫医疗组",
              "nextStage": 4
            },
            {
              "text": "封锁车厢",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "部分乘客理解，但仍有骚动。",
          "options": [
            {
              "text": "开放VIP休息室安抚",
              "nextStage": 6
            },
            {
              "text": "分发镇定剂",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "医疗组到达，但物资不足。",
          "options": [
            {
              "text": "征用乘客药品",
              "nextStage": 8
            },
            {
              "text": "减少剂量",
              "nextStage": 9
            }
          ]
        }
      ]
    },
    {
      "name": "信号员",
      "role": "通讯联络",
      "storyline": [
        {
          "stage": 1,
          "text": "与总部失去联系，无法获得援助。",
          "options": [
            {
              "text": "尝试卫星通讯",
              "nextStage": 2
            },
            {
              "text": "使用备用天线",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "卫星通讯受干扰，信号微弱。",
          "options": [
            {
              "text": "放大信号",
              "nextStage": 4
            },
            {
              "text": "发送莫尔斯电码",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "备用天线损坏，需要修复。",
          "options": [
            {
              "text": "自行修理",
              "nextStage": 6
            },
            {
              "text": "指派技术员",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "信号放大导致系统过载。",
          "options": [
            {
              "text": "关闭非必要系统",
              "nextStage": 8
            },
            {
              "text": "冒风险继续",
              "nextStage": 9
            }
          ]
        }
      ]
    },
    {
      "name": "保安队长",
      "role": "安全维护",
      "storyline": [
        {
          "stage": 1,
          "text": "发现可疑乘客携带危险品。",
          "options": [
            {
              "text": "立即逮捕",
              "nextStage": 2
            },
            {
              "text": "监视其行动",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "逮捕引发同伙反抗，发生枪战。",
          "options": [
            {
              "text": "启用电磁屏障",
              "nextStage": 4
            },
            {
              "text": "疏散乘客",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "乘客进入引擎室，意图破坏。",
          "options": [
            {
              "text": "追捕",
              "nextStage": 6
            },
            {
              "text": "封锁引擎室",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "电磁屏障启动，但部分设备受损。",
          "options": [
            {
              "text": "修复设备",
              "nextStage": 8
            },
            {
              "text": "优先控制局势",
              "nextStage": 9
            }
          ]
        }
      ]
    }
  ],
  "items": [
