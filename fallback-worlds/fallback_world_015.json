      "id": "npc1",
      "name": "火星矿业代表",
      "position": [
        3,
        8
      ],
      "dialogue": "太阳币要崩了！快抛售！",
      "storyline": [
        {
          "stage": 0,
          "text": "火星矿业代表焦急地挥舞着数据板。",
          "options": [
            {
              "text": "安抚他，说一切尽在掌握",
              "nextStage": 1
            },
            {
              "text": "命令他立即抛售所有火星矿业债券",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "text": "代表半信半疑，但暂时冷静下来。",
          "options": [
            {
              "text": "私下转移资产到土星环储备",
              "nextStage": 3
