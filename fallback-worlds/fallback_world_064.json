            {
              "text": "恢复正常",
              "nextStage": 0,
              "effect": "restart"
            }
          ]
        },
        {
          "stage": 3,
          "text": "管理者收了钱，时间增加10秒。",
          "options": [
            {
              "text": "谢谢",
              "nextStage": 0,
              "effect": "none"
            },
            {
              "text": "再买",
              "nextStage": 1,
              "effect": "money"
            }
          ]
        }
      ]
    },
    {
      "id": "npc5",
      "name": "神秘黑客",
      "dialog": "我可以黑入税务系统。",
      "position": {
        "x": 2,
        "y": 9
      },
      "storyline": [
        {
          "stage": 0,
          "text": "黑客低声说：'给我你的登录凭证，我帮你清零。'",
          "options": [
            {
              "text": "给",
