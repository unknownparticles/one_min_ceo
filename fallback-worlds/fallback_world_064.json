  "npcs": [
    {
      "id": "npc1",
      "name": "审计员Alpha",
      "dialog": "你的宇宙税表有21处异常！",
      "position": {
        "x": 2,
        "y": 1
      },
      "storyline": [
        {
          "stage": 0,
          "text": "审计员Alpha盯着你：'你的收入申报与平行宇宙产出不匹配。'",
          "options": [
            {
              "text": "解释这是多重宇宙波动",
              "nextStage": 1,
              "effect": "none"
            },
            {
              "text": "直接贿赂星光币",
              "nextStage": 2,
              "effect": "money"
            }
          ]
        },
        {
          "stage": 1,
          "text": "Alpha冷笑：'波动？我们只认标准宇宙汇率。'",
          "options": [
            {
              "text": "请求重新计算",
              "nextStage": 3,
              "effect": "none"
            },
            {
              "text": "威胁举报上级",
              "nextStage": 4,
              "effect": "anger"
            }
          ]
        },
        {
          "stage": 2,
          "text": "Alpha收下星光币，但警告下不为例。",
          "options": [
            {
              "text": "表示感谢",
              "nextStage": 3,
              "effect": "none"
            },
            {
              "text": "询问更多漏洞",
              "nextStage": 4,
              "effect": "info"
            }
          ]
        },
        {
          "stage": 3,
          "text": "Alpha叹了口气：'好吧，我重新计算，但后果自负。'",
          "options": [
            {
              "text": "接受重算",
              "nextStage": 0,
              "effect": "restart"
            },
            {
              "text": "坚持原方案",
              "nextStage": 0,
              "effect": "restart"
            }
          ]
        },
        {
          "stage": 4,
          "text": "Alpha愤怒地拍桌：'你被列入黑名单！'",
          "options": [
            {
              "text": "道歉",
              "nextStage": 0,
              "effect": "restart"
            },
            {
              "text": "逃跑",
              "nextStage": 2,
              "effect": "flee"
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "平行宇宙CEO",
      "dialog": "你的决策导致我们宇宙亏损！",
      "position": {
        "x": 8,
        "y": 3
      },
      "storyline": [
        {
          "stage": 0,
          "text": "CEO愤怒地指着屏幕：'看，你的税务规划让我们损失了三个维度！'",
          "options": [
            {
              "text": "承认失误",
              "nextStage": 1,
              "effect": "none"
            },
            {
              "text": "推卸给助手",
              "nextStage": 2,
              "effect": "blame"
            }
          ]
        },
        {
          "stage": 1,
          "text": "CEO稍微平静：'那你怎么补偿？'",
          "options": [
            {
              "text": "提出新的避税方案",
              "nextStage": 3,
              "effect": "none"
            },
            {
              "text": "承诺下季度补上",
              "nextStage": 2,
              "effect": "none"
            }
          ]
        },
        {
          "stage": 2,
          "text": "CEO冷笑：'你的助手已经被解雇了。'",
          "options": [
            {
              "text": "辞职",
              "nextStage": 0,
              "effect": "gameover"
            },
            {
              "text": "请求再给一次机会",
              "nextStage": 3,
              "effect": "none"
            }
          ]
        },
        {
          "stage": 3,
          "text": "CEO勉强同意：'但你要签下这份对赌协议。'",
          "options": [
            {
              "text": "签",
              "nextStage": 0,
              "effect": "restart"
            },
            {
              "text": "不签",
              "nextStage": 2,
              "effect": "anger"
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "星际律师",
      "dialog": "我可以帮你钻法律漏洞。",
      "position": {
        "x": 13,
        "y": 1
      },
      "storyline": [
        {
          "stage": 0,
          "text": "律师神秘地说：'我知道一个跨宇宙的免税条款。'",
          "options": [
            {
              "text": "快告诉我",
              "nextStage": 1,
              "effect": "none"
            },
            {
              "text": "我不信",
              "nextStage": 2,
              "effect": "none"
            }
          ]
        },
        {
          "stage": 1,
          "text": "律师伸出五根手指：'费用是5000星光币。'",
          "options": [
            {
              "text": "支付",
              "nextStage": 3,
              "effect": "money"
            },
            {
              "text": "讨价还价",
              "nextStage": 2,
              "effect": "none"
            }
          ]
        },
        {
          "stage": 2,
          "text": "律师耸肩：'那你就等着被罚吧。'",
          "options": [
            {
              "text": "离开",
              "nextStage": 0,
              "effect": "restart"
            },
            {
              "text": "叫保安",
              "nextStage": 0,
              "effect": "gameover"
            }
          ]
        },
        {
          "stage": 3,
          "text": "律师给了你一份文件：'签了它，宇宙税务局就查不到你。'",
          "options": [
            {
              "text": "签",
              "nextStage": 0,
              "effect": "win"
            },
            {
              "text": "先验证",
              "nextStage": 2,
              "effect": "none"
            }
          ]
        }
      ]
    },
    {
