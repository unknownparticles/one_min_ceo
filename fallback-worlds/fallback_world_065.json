    {
      "id": "npc_cryo_engineer",
      "name": "低温工程师林晓",
      "dialogue": "林晓颤抖着说：'老板，3号罐温度失控了！'",
      "storyline": [
        {
          "stage": 0,
          "dialogue": "林晓看着仪表盘：'反物质容器温度在上升，需要立即冷却！'",
          "options": [
            {
              "text": "启动紧急冷冻协议",
              "nextStage": 1,
              "effect": "coolant"
            },
            {
              "text": "让他手动检查阀门",
              "nextStage": 2,
              "effect": "manual"
            }
          ]
        },
        {
          "stage": 1,
          "dialogue": "冷却系统启动，但压力异常。",
          "options": [
            {
              "text": "增加冷却剂",
              "nextStage": 3,
              "effect": "overcool"
            },
            {
              "text": "检查管道泄漏",
              "nextStage": 4,
              "effect": "leak"
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "林晓跑向阀门，但地面湿滑。",
          "options": [
            {
              "text": "提醒他小心",
              "nextStage": 4,
              "effect": "caution"
            },
            {
              "text": "让他快点",
              "nextStage": 3,
              "effect": "hurry"
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "冷却剂过量，容器结冰。",
          "options": [
            {
              "text": "停止冷却",
              "nextStage": 4,
              "effect": "stop"
            },
            {
              "text": "加热解冻",
              "nextStage": 4,
              "effect": "heat"
            }
          ]
        },
        {
          "stage": 4,
          "dialogue": "林晓擦汗：'暂时稳定了，但需要持续监控。'",
          "options": [
            {
              "text": "派他去监控室",
              "nextStage": "end_stable",
              "effect": "monitor"
            },
            {
              "text": "让他休息，换人",
              "nextStage": "end_stable",
              "effect": "rest"
            }
          ]
        }
      ],
      "position": [
        2,
        2
      ]
    },
    {
      "id": "npc_quantum_accountant",
      "name": "量子会计师赵钱",
      "dialogue": "赵钱抱着账本：'老板，我们的反物质储备会计上有个bug！'",
      "storyline": [
        {
          "stage": 0,
          "dialogue": "赵钱焦急地说：'账面和实际库存对不上，差了一个量子态！'",
          "options": [
            {
              "text": "重算所有数据",
              "nextStage": 1,
              "effect": "recalc"
            },
            {
              "text": "忽略差异，先救火",
              "nextStage": 2,
              "effect": "ignore"
            }
          ]
        },
        {
          "stage": 1,
          "dialogue": "数据重算中，发现一个隐藏交易。",
          "options": [
            {
              "text": "追踪交易来源",
              "nextStage": 3,
              "effect": "trace"
            },
            {
              "text": "直接修正账目",
              "nextStage": 3,
              "effect": "fix"
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "赵钱犹豫：'但是财务漏洞可能引发危机。'",
          "options": [
            {
              "text": "先处理火灾",
              "nextStage": 3,
              "effect": "fire_first"
            },
            {
              "text": "给他五分钟处理",
              "nextStage": 3,
              "effect": "five_min"
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "赵钱发现了原因：'有人篡改了日志！'",
          "options": [
            {
              "text": "调查内部人员",
              "nextStage": "end_investigate",
              "effect": "internal"
            },
            {
              "text": "报警处理",
              "nextStage": "end_investigate",
              "effect": "police"
            }
          ]
        }
      ],
      "position": [
        3,
        5
      ]
    },
    {
