          ]
        },
        {
          "stage": 1,
          "text": "赵铁柱困惑：可是他们没带钱。",
          "options": [
            {
              "id": "opt_11",
              "text": "先赊账，开业再说。",
              "nextStage": 3
            },
            {
              "id": "opt_12",
              "text": "让他们打工抵债。",
              "nextStage": 3
