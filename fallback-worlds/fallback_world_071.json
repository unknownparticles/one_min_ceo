        {
          "stage": 2,
          "text": "马文惊讶：反物质气球会爆炸！",
          "options": [
            {
              "id": "opt_5",
              "text": "那就炸出个广告效果。",
              "nextStage": 3
            },
            {
              "id": "opt_6",
              "text": "撤回，太危险。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "马文点头：明白了，我马上去办。",
          "options": [
            {
              "id": "opt_7",
              "text": "好，继续工作。",
              "nextStage": -1
            },
            {
              "id": "opt_8",
              "text": "等等，还有事。",
              "nextStage": 0
            }
          ]
        }
      ]
    },
    {
      "id": "npc_2",
      "name": "保安队长赵铁柱",
      "x": 10,
      "y": 4,
      "role": "保安队长",
      "dialogue": "老板！外星人闯进停车场了！",
      "storyline": [
        {
          "stage": 0,
          "text": "赵铁柱一脸严肃。",
          "options": [
            {
              "id": "opt_9",
              "text": "给他们办会员卡。",
              "nextStage": 1
            },
            {
              "id": "opt_10",
              "text": "用激光网困住他们。",
              "nextStage": 2
