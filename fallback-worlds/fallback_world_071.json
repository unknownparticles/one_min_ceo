      "name": "营销总监马文",
      "x": 5,
      "y": 2,
      "role": "营销总监",
      "dialogue": "老板！我们的宇宙气球广告被黑洞吸走了！",
      "storyline": [
        {
          "stage": 0,
          "text": "营销总监马文慌张地跑过来。",
          "options": [
            {
              "id": "opt_1",
              "text": "再放100个气球！",
              "nextStage": 1
            },
            {
              "id": "opt_2",
              "text": "用反物质气球试试。",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 1,
          "text": "马文泪流满面：可是气球工厂也被吸走了！",
          "options": [
            {
              "id": "opt_3",
              "text": "那就用星际投影。",
              "nextStage": 3
            },
            {
              "id": "opt_4",
              "text": "算了，放弃气球。",
              "nextStage": 3
