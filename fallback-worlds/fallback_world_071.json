          "text": "赵铁柱提醒：激光网可能损坏飞船。",
          "options": [
            {
              "id": "opt_13",
              "text": "改用欢迎毯。",
              "nextStage": 3
            },
            {
              "id": "opt_14",
              "text": "直接谈判。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "赵铁柱敬礼：明白，我立刻处理。",
          "options": [
            {
              "id": "opt_15",
              "text": "做得好。",
              "nextStage": -1
            },
            {
              "id": "opt_16",
              "text": "再报告情况。",
              "nextStage": 0
            }
          ]
        }
      ]
    },
