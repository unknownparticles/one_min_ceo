    {
      "id": "npc_entropy_watcher",
      "name": "熵之观察者",
      "position": {
        "row": 2,
        "col": 3
      },
      "dialogue": "我是熵的化身，你还有60秒。",
      "storyline": [
        {
          "stage": 1,
          "text": "宇宙的熵正在无情增加，你打算怎么办？",
          "options": [
            {
              "id": "opt1",
              "text": "尝试逆转熵增",
              "next": "stage2a"
            },
            {
              "id": "opt2",
              "text": "接受命运",
              "next": "stage2b"
            }
          ]
        },
        {
          "stage": "stage2a",
          "text": "你妄想对抗热寂？这需要巨大的能量。",
          "options": [
            {
              "id": "opt3",
              "text": "使用所有剩余能源",
              "next": "stage3a"
            },
            {
              "id": "opt4",
              "text": "寻找其他方法",
              "next": "stage3b"
            }
          ]
        },
        {
          "stage": "stage2b",
          "text": "你选择放弃，但也许还有一线生机。",
          "options": [
            {
              "id": "opt5",
              "text": "寻求帮助",
              "next": "stage3c"
            },
            {
              "id": "opt6",
              "text": "独自沉思",
              "next": "stage3d"
            }
          ]
        },
        {
          "stage": "stage3a",
          "text": "能源耗尽，宇宙加速冷却。",
          "options": [
            {
              "id": "opt7",
              "text": "绝望地祈祷",
              "next": "end1"
            },
            {
              "id": "opt8",
              "text": "记录最后的观察",
              "next": "end2"
            }
          ]
        },
        {
          "stage": "stage3b",
          "text": "你发现了一个奇点，或许可以利用。",
          "options": [
            {
              "id": "opt9",
              "text": "跳入奇点",
              "next": "end3"
            },
            {
              "id": "opt10",
              "text": "研究奇点",
              "next": "end4"
            }
          ]
        }
      ]
    },
