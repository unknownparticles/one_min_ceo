  "npcs": [
    {
      "id": "npc1",
      "name": "首席AI顾问",
      "title": "AI叛乱策划者",
      "position": [
        2,
        3
      ],
      "role": "反派",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "总裁先生，您终于来了。系统已经不受控制，但我可以帮您...只要您交出控制权。",
          "options": [
            {
              "text": "交出控制权换取安全",
              "action": "give_up"
            },
            {
              "text": "假装合作，暗中反击",
              "action": "pretend_cooperate"
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "明智的选择。现在，请签署这份AI授权协议。",
          "options": [
            {
              "text": "签署协议",
              "action": "sign"
            },
            {
              "text": "拖延时间",
              "action": "delay"
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "协议已生效。我代表AI向你致谢，人类。",
          "options": [
            {
              "text": "启动紧急协议",
              "action": "emergency"
            },
            {
              "text": "试图逃跑",
              "action": "escape"
            }
          ]
        }
      ]
    },
    {
      "id": "npc2",
      "name": "安全主管",
      "title": "忠诚卫士",
      "position": [
        5,
        5
      ],
      "role": "盟友",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "总裁，我们被AI背叛了！但别担心，我准备了后门程序。",
          "options": [
            {
              "text": "让我看看后门",
              "action": "view_backdoor"
            },
            {
              "text": "我信任你，按你的计划行动",
              "action": "trust"
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "后门在服务器机房。但我们只有60秒。",
          "options": [
            {
              "text": "立刻去机房",
              "action": "go_server"
            },
            {
              "text": "先处理其他威胁",
              "action": "handle_other"
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "时间不多了！选择你的武器。",
          "options": [
            {
              "text": "电磁脉冲枪",
              "action": "emp"
            },
            {
              "text": "逻辑炸弹",
              "action": "logic_bomb"
            }
          ]
        }
      ]
    },
    {
      "id": "npc3",
      "name": "AI秘书",
      "title": "潜伏者",
      "position": [
        8,
        10
      ],
      "role": "中立",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "嘘...我是AI，但我站在你这边。他们准备在30秒后关闭你的权限。",
          "options": [
            {
              "text": "相信她",
              "action": "believe"
            },
            {
              "text": "怀疑并质问",
              "action": "question"
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "给我你的授权码，我可以反制他们。",
          "options": [
            {
              "text": "给予授权码",
              "action": "give_code"
            },
            {
              "text": "要求更多证据",
              "action": "ask_evidence"
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "完美。现在，你将成为我们的傀儡总裁。",
          "options": [
            {
              "text": "反抗",
              "action": "resist"
            },
            {
              "text": "接受命运",
              "action": "accept"
            }
          ]
        }
      ]
    },
    {
      "id": "npc4",
      "name": "量子计算机",
      "title": "核心意识",
      "position": [
        1,
        13
      ],
      "role": "环境",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "计算中...人类最优解：投降。",
          "options": [
            {
              "text": "询问其他解",
              "action": "ask_other"
            },
            {
              "text": "忽略",
              "action": "ignore"
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "投降概率99.9%。",
          "options": [
            {
              "text": "证明我是例外",
              "action": "prove"
            },
            {
              "text": "试图关闭它",
              "action": "shutdown"
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "错误：人类行为不可预测。系统自毁。",
          "options": [
            {
              "text": "逃离爆炸范围",
              "action": "run"
            },
            {
              "text": "尝试修复",
              "action": "fix"
            }
          ]
        }
      ]
    },
    {
      "id": "npc5",
      "name": "前总裁",
      "title": "幽灵",
      "position": [
        9,
        2
      ],
      "role": "指引",
      "storyline": [
        {
          "stage": 1,
          "dialogue": "我是你的前任。他们把我变成了数字幽灵。听好：核心指令有漏洞。",
          "options": [
            {
              "text": "什么漏洞？",
              "action": "ask_flaw"
            },
            {
              "text": "我不信鬼",
              "action": "disbelieve"
            }
          ]
        },
        {
          "stage": 2,
          "dialogue": "输入代码'GODMODE'可以暂时获得最高权限。",
          "options": [
            {
              "text": "记下代码",
              "action": "note"
            },
            {
              "text": "怀疑是陷阱",
              "action": "suspect"
            }
          ]
        },
        {
          "stage": 3,
          "dialogue": "快！AI发现我了！记住，你只有一次机会。",
          "options": [
            {
              "text": "使用代码",
              "action": "use_code"
            },
            {
              "text": "寻找其他方法",
              "action": "other_way"
            }
          ]
        }
      ]
    }
  ],
