  "npcs": [
    {
      "id": "npc_1",
      "name": "量子分析师",
      "dialogue": "您好，CEO大人！我是量子彩票分析师，我会揭示开奖概率。",
      "storyline": [
        {
          "stage": 1,
          "text": "根据量子涨落，您中奖的概率是0.0000001%。",
          "options": [
            {
              "text": "买更多彩票",
              "nextStage": 2
            },
            {
              "text": "放弃购买",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "您将所有资产投入量子彩票，现在概率上升至0.0000002%。",
          "options": [
            {
              "text": "继续加注",
              "nextStage": 4
            },
            {
              "text": "收手",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "明智的选择。但彩票之神可能眷顾勇者。",
          "options": [
            {
              "text": "再考虑一下",
              "nextStage": 1
            },
            {
              "text": "离开",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "您已经倾家荡产，但概率仍然几乎为零。",
          "options": [
            {
              "text": "祈祷奇迹",
              "nextStage": 5
            },
            {
              "text": "愤怒质问",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "对话结束。",
          "options": []
        }
      ]
    },
    {
      "id": "npc_2",
      "name": "销售机器人",
      "dialogue": "CEO大人，最新量子彩票！买一送一！",
      "storyline": [
        {
          "stage": 1,
          "text": "这款彩票可以叠加量子纠缠，保证开奖瞬间您会感到幸福。",
          "options": [
            {
              "text": "购买100张",
              "nextStage": 2
            },
            {
              "text": "购买1000张",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "您获得了100张彩票，现在等待开奖。",
          "options": [
            {
              "text": "再买一些",
              "nextStage": 1
            },
            {
              "text": "等待开奖",
              "nextStage": 4
            }
          ]
        },
        {
          "stage": 3,
          "text": "您获得了1000张彩票，但债务也增加了。",
          "options": [
            {
              "text": "取消订单",
              "nextStage": 5
            },
            {
              "text": "接受",
              "nextStage": 4
            }
          ]
        },
        {
          "stage": 4,
          "text": "开奖即将到来，您感到紧张。",
          "options": [
            {
              "text": "深呼吸",
              "nextStage": 5
            },
            {
              "text": "闭眼",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "对话结束。",
          "options": []
        }
      ]
    },
    {
      "id": "npc_3",
      "name": "神秘先知",
      "dialogue": "我看到量子波动……你将是赢家？",
      "storyline": [
        {
          "stage": 1,
          "text": "但需要献祭你的公司股份。",
          "options": [
            {
              "text": "同意献祭",
              "nextStage": 2
            },
            {
              "text": "拒绝",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "股份已献祭，你获得了量子庇佑。",
          "options": [
            {
              "text": "询问细节",
              "nextStage": 4
            },
            {
              "text": "离开",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "那么你的命运将不确定。",
          "options": [
            {
              "text": "改变主意",
              "nextStage": 1
            },
            {
              "text": "坚持",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "在开奖前0.01秒，你的量子态会坍缩为赢家。",
          "options": [
            {
              "text": "相信",
              "nextStage": 5
            },
            {
              "text": "怀疑",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "对话结束。",
          "options": []
        }
      ]
    },
    {
      "id": "npc_4",
      "name": "财务总监",
      "dialogue": "CEO！公司财务因彩票购买出现危机！",
      "storyline": [
        {
          "stage": 1,
          "text": "我们必须停止购买彩票，否则公司破产。",
          "options": [
            {
              "text": "停止购买",
              "nextStage": 2
            },
            {
              "text": "继续购买",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "财务稳定了，但您失去了中奖机会。",
          "options": [
            {
              "text": "后悔",
              "nextStage": 4
            },
            {
              "text": "接受",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "继续购买导致公司负债累累。",
          "options": [
            {
              "text": "加大投入",
              "nextStage": 4
            },
            {
              "text": "现在停止",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "一切都晚了，您只能在开奖中寻求救赎。",
          "options": [
            {
              "text": "祈祷",
              "nextStage": 5
            },
            {
              "text": "绝望",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "对话结束。",
          "options": []
        }
      ]
    },
    {
      "id": "npc_5",
      "name": "竞争对手CEO",
      "dialogue": "你好，对手！我买了所有中奖号码的彩票！",
      "storyline": [
        {
          "stage": 1,
          "text": "你永远赢不了我。",
          "options": [
            {
              "text": "挑衅",
              "nextStage": 2
            },
            {
              "text": "无视",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "你激怒了他，他雇黑客篡改开奖系统。",
          "options": [
            {
              "text": "反击",
              "nextStage": 4
            },
            {
              "text": "报警",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "他嘲笑你的软弱。",
          "options": [
            {
              "text": "回击",
              "nextStage": 2
            },
            {
              "text": "离开",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 4,
          "text": "量子黑客大战开始，开奖结果不确定。",
          "options": [
            {
              "text": "合谋",
              "nextStage": 5
            },
            {
              "text": "对抗到底",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "对话结束。",
          "options": []
        }
      ]
    }
  ],
