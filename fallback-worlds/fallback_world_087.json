  "npcs": [
    {
      "id": "npc1",
      "name": "龟丞相",
      "type": "advisor",
      "dialogue": "殿下，继承仪式即将开始，您需要集齐七颗龙珠。",
      "storyline": [
        {
          "stage": 1,
          "text": "龟丞相捋着胡须，神色凝重。",
          "options": [
            {
              "text": "龙珠在哪？",
              "nextStage": 2
            },
            {
              "text": "我还没准备好。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "龙珠散落在龙宫各处，还有一颗被蟹将军私藏。",
          "options": [
            {
              "text": "去找蟹将军。",
              "nextStage": 4
            },
            {
              "text": "先找其他龙珠。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "时间不等人，殿下！60秒后您必须站上祭坛。",
          "options": [
            {
              "text": "好，我出发。",
              "nextStage": 2
            },
            {
              "text": "再想想办法。",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 4,
          "text": "蟹将军在宝库中，但他要求用宝物交换。",
          "options": [
            {
              "text": "给他宝物。",
              "nextStage": 5
            },
            {
              "text": "用武力夺取。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "龟丞相点头：明智的选择。",
          "options": [
            {
              "text": "告辞。",
              "nextStage": -1
            },
            {
              "text": "还有什么建议？",
              "nextStage": 6
            }
          ]
        },
        {
          "stage": 6,
          "text": "小心水母刺客，他们可能已经潜入。",
          "options": [
            {
              "text": "明白了。",
              "nextStage": -1
            },
            {
              "text": "我会注意。",
              "nextStage": -1
            }
          ]
        }
      ],
      "position": {
        "row": 2,
        "col": 4
      }
    },
    {
      "id": "npc2",
      "name": "蟹将军",
      "type": "guard",
      "dialogue": "想要龙珠？拿你的王冠来换！",
      "storyline": [
        {
          "stage": 1,
          "text": "蟹将军横着钳子，傲慢地挡住去路。",
          "options": [
            {
              "text": "交出龙珠！",
              "nextStage": 2
            },
            {
              "text": "我用宝物交换。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "武力挑战！蟹将军挥舞大钳。",
          "options": [
            {
              "text": "战斗！",
              "nextStage": 4
            },
            {
              "text": "理智谈判。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 3,
          "text": "蟹将军伸出钳子：我要一颗夜明珠。",
          "options": [
            {
              "text": "给他夜明珠。",
              "nextStage": 5
            },
            {
              "text": "没有，换个条件。",
              "nextStage": 6
            }
          ]
        },
        {
          "stage": 4,
          "text": "你击败了蟹将军，他交出龙珠。",
          "options": [
            {
              "text": "拿走龙珠。",
              "nextStage": -1
            },
            {
              "text": "饶他一命。",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 5,
          "text": "蟹将军满意地交出龙珠。",
          "options": [
            {
              "text": "谢谢。",
              "nextStage": -1
            },
            {
              "text": "告辞。",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 6,
          "text": "那我不给。蟹将军转身要走。",
          "options": [
            {
              "text": "等等，我有夜明珠。",
              "nextStage": 5
            },
            {
              "text": "算了，找别的龙珠。",
              "nextStage": -1
            }
          ]
        }
      ],
      "position": {
        "row": 2,
        "col": 8
      }
    },
    {
      "id": "npc3",
      "name": "水母刺客",
      "type": "enemy",
      "dialogue": "你的死期到了！",
      "storyline": [
        {
          "stage": 1,
          "text": "透明的水母幽灵般出现，触手带电。",
          "options": [
            {
              "text": "防御！",
              "nextStage": 2
            },
            {
              "text": "逃跑！",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "你挡住了攻击，但损失了一些体力。",
          "options": [
            {
              "text": "反击！",
              "nextStage": 4
            },
            {
              "text": "寻求帮助。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "你逃到安全区，但水母紧追不舍。",
          "options": [
            {
              "text": "回头战斗。",
              "nextStage": 2
            },
            {
              "text": "继续跑。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 4,
          "text": "你击退了水母刺客，获得一颗龙珠。",
          "options": [
            {
              "text": "拾取龙珠。",
              "nextStage": -1
            },
            {
              "text": "查看伤势。",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 5,
          "text": "龟丞相出现，用拐杖击退水母。",
          "options": [
            {
              "text": "感谢丞相。",
              "nextStage": -1
            },
            {
              "text": "继续前进。",
              "nextStage": -1
            }
          ]
        }
      ],
      "position": {
        "row": 5,
        "col": 5
      }
    },
    {
      "id": "npc4",
      "name": "龙宫舞女",
      "type": "entertainer",
      "dialogue": "殿下，跳一支祈福舞吧！",
      "storyline": [
        {
          "stage": 1,
          "text": "舞女们翩翩起舞，水袖飘摇。",
          "options": [
            {
              "text": "一起跳舞。",
              "nextStage": 2
            },
            {
              "text": "没时间，跳过。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "你笨拙地跳舞，但舞女们很开心，给了你一颗龙珠。",
          "options": [
            {
              "text": "收下龙珠。",
              "nextStage": -1
