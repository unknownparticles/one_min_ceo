            {
              "text": "继续跳舞。",
              "nextStage": 2
            }
          ]
        },
        {
          "stage": 3,
          "text": "舞女们失望地散去。",
          "options": [
            {
              "text": "等等，我跳。",
              "nextStage": 2
            },
            {
              "text": "对不起。",
              "nextStage": -1
            }
          ]
        }
      ],
      "position": {
        "row": 8,
        "col": 7
      }
    },
    {
      "id": "npc5",
      "name": "龙宫宝库守卫",
      "type": "guard",
      "dialogue": "口令！",
      "storyline": [
        {
          "stage": 1,
          "text": "守卫手持三叉戟，严肃地站在宝库前。",
          "options": [
            {
              "text": "我是继承人。",
              "nextStage": 2
            },
            {
              "text": "我有密令。",
              "nextStage": 3
            }
          ]
        },
        {
          "stage": 2,
          "text": "守卫点头：殿下请进。但你需要找到钥匙。",
          "options": [
            {
              "text": "钥匙在哪？",
              "nextStage": 4
            },
            {
              "text": "强行进入。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 3,
          "text": "守卫怀疑：什么密令？",
          "options": [
            {
              "text": "海神波塞冬。",
              "nextStage": 6
            },
            {
              "text": "龙王万岁。",
              "nextStage": 7
            }
          ]
        },
        {
          "stage": 4,
          "text": "钥匙在龟丞相那里。",
          "options": [
            {
              "text": "去找丞相。",
              "nextStage": -1
            },
            {
              "text": "自己撬锁。",
              "nextStage": 5
            }
          ]
        },
        {
          "stage": 5,
          "text": "强行闯入，守卫与你战斗。你打败守卫，进入宝库。",
          "options": [
            {
              "text": "拿走宝物。",
              "nextStage": -1
            },
            {
              "text": "只是看看。",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 6,
          "text": "守卫让开：原来是海神使者。",
          "options": [
            {
              "text": "进入宝库。",
              "nextStage": -1
            },
            {
              "text": "询问龙珠。",
              "nextStage": -1
            }
          ]
        },
        {
          "stage": 7,
          "text": "守卫大笑：这个老套。不行！",
          "options": [
            {
              "text": "再试一次。",
              "nextStage": 3
