  "npcs": [
    {
      "id": "npc1",
      "name": "章鱼顾问",
      "x": 3,
      "y": 2,
      "dialogue": "陛下，国库的珍珠正在被鲸鱼巨鳄吞噬！",
      "storyline": [
        {
          "stage": 0,
          "text": "您来得正好，财政大臣！海蛇集团正在抛售国债，我们需要紧急干预。",
          "options": [
            {
              "text": "启动紧急印钞机",
              "nextStage": 1,
              "effect": "inflation"
            },
            {
              "text": "向鲨鱼银行借款",
              "nextStage": 2,
              "effect": "debt"
            }
          ]
        },
        {
          "stage": 1,
          "text": "印钞导致海藻通胀，平民怨声载道。您必须想其他办法。",
          "options": [
            {
              "text": "征收珊瑚税",
              "nextStage": 2,
              "effect": "tax"
            },
            {
              "text": "出售海底油田",
              "nextStage": 3,
              "effect": "sell_oil"
            }
          ]
        },
        {
          "stage": 2,
          "text": "借款利息高昂，债务如同海沟深不见底。",
          "options": [
            {
              "text": "发行新债券",
              "nextStage": 3,
              "effect": "bonds"
            },
            {
              "text": "请求海神援助",
              "nextStage": 4,
              "effect": "pray"
            }
          ]
        },
        {
          "stage": 3,
          "text": "债券无人问津，海神沉默不语。",
          "options": [
            {
              "text": "宣布破产",
              "nextStage": 4,
              "effect": "bankruptcy"
            },
            {
              "text": "发动对珊瑚礁的战争",
              "nextStage": 5,
              "effect": "war"
            }
          ]
        },
        {
          "stage": 4,
          "text": "破产导致王国崩溃，您被流放到深海沟。",
          "options": [
            {
              "text": "接受命运",
              "nextStage": 5,
              "effect": "end"
            },
            {
              "text": "试图逃跑",
              "nextStage": 5,
              "effect": "escape"
            }
          ]
        },
        {
          "stage": 5,
          "text": "故事结束。",
          "options": []
        }
      ]
    },
    {
      "id": "npc2",
      "name": "美人鱼秘书",
      "x": 7,
      "y": 4,
      "dialogue": "大臣，您的咖啡杯里全是海水！",
      "storyline": [
        {
          "stage": 0,
          "text": "报告大臣，审计发现王国金库其实是一堆空贝壳！",
          "options": [
            {
              "text": "处决审计官",
              "nextStage": 1,
              "effect": "kill"
            },
            {
              "text": "假装没听见",
              "nextStage": 2,
              "effect": "ignore"
            }
          ]
        },
        {
          "stage": 1,
          "text": "审计官被处决，但消息泄露，民众暴动。",
          "options": [
            {
              "text": "调集水母军队镇压",
              "nextStage": 3,
              "effect": "repress"
            },
            {
              "text": "宣布这是假新闻",
              "nextStage": 4,
              "effect": "fake"
            }
          ]
        },
        {
          "stage": 2,
          "text": "您假装没听见，但谣言四起，信用崩塌。",
          "options": [
            {
              "text": "召开新闻发布会",
              "nextStage": 4,
              "effect": "press"
            },
            {
              "text": "潜逃至海藻森林",
              "nextStage": 5,
              "effect": "flee"
            }
          ]
        },
        {
          "stage": 3,
          "text": "水母军队倒戈，您被俘。",
          "options": [
            {
              "text": "投降",
              "nextStage": 5,
              "effect": "surrender"
            },
            {
              "text": "自杀",
              "nextStage": 5,
              "effect": "suicide"
            }
          ]
        },
        {
          "stage": 4,
          "text": "新闻发布会失败，民众要求您下台。",
          "options": [
            {
              "text": "辞职",
              "nextStage": 5,
              "effect": "resign"
            },
            {
              "text": "用魔法改变记忆",
              "nextStage": 5,
              "effect": "magic"
            }
          ]
        },
        {
          "stage": 5,
          "text": "故事结束。",
          "options": []
        }
      ]
    },
    {
