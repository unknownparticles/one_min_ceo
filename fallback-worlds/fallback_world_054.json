              "effect": "revert"
            }
          ]
        },
        {
          "stage": 4,
          "text": "放任导致海星币贬值，经济崩溃。",
          "options": [
            {
              "text": "求助于章鱼顾问",
              "nextStage": 5,
              "effect": "ask_octopus"
            },
            {
              "text": "向国民道歉",
              "nextStage": 5,
              "effect": "apologize"
            }
          ]
        },
        {
          "stage": 5,
          "text": "故事结束。",
          "options": []
        }
