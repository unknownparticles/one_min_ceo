            {
              "text": "无视他",
              "nextStage": 4,
              "effect": "ignore"
            }
          ]
        },
        {
          "stage": 3,
          "text": "管制导致海星黑市，经济更加恶化。",
          "options": [
            {
              "text": "发动海星清洗",
              "nextStage": 5,
              "effect": "clean"
            },
