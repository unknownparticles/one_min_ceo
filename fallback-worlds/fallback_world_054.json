      "y": 6,
      "dialogue": "根据我的模型，我们需要更多海蜗牛作为货币。",
      "storyline": [
        {
          "stage": 0,
          "text": "大臣，我有一套挽救经济的方案：推行海星币！",
          "options": [
            {
              "text": "采纳方案",
              "nextStage": 1,
              "effect": "adopt"
            },
            {
              "text": "嘲笑他",
              "nextStage": 2,
              "effect": "mock"
            }
          ]
        },
        {
          "stage": 1,
          "text": "海星币发行后，市场混乱，海星大量繁殖。",
          "options": [
            {
              "text": "管制海星",
              "nextStage": 3,
              "effect": "regulate"
            },
