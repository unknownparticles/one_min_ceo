      "id": "npc_zorg",
      "name": "佐格大使",
      "type": "友好外星人",
      "position": [
        7,
        3
      ],
      "dialog": "欢迎，局长！我们的飞船将在60秒后登陆。",
      "storyline": [
        {
          "stage": 0,
          "trigger": "初次见面",
          "text": "我是佐格，代表泽塔星。我们期待和平移民。",
          "options": [
            {
              "text": "要求查看移民签证",
              "nextStage": 1,
              "effect": "获得签证信息"
            },
            {
              "text": "直接批准登陆",
              "nextStage": 2,
              "effect": "风险增加"
            }
          ]
        },
        {
          "stage": 1,
          "trigger": "查看签证后",
          "text": "签证齐全，但我们携带了特殊矿石。",
          "options": [
            {
              "text": "要求申报矿石",
              "nextStage": 2,
              "effect": "获得矿石信息"
            },
            {
              "text": "无视矿石",
              "nextStage": 2,
              "effect": "环境风险"
            }
          ]
        },
        {
          "stage": 2,
          "trigger": "最后警告",
          "text": "时间不多了，请决定是否允许我们登陆。",
          "options": [
            {
              "text": "允许登陆",
              "nextStage": 3,
              "effect": "移民成功"
            },
            {
              "text": "拒绝登陆",
              "nextStage": 3,
              "effect": "外交危机"
            }
          ]
        },
        {
          "stage": 3,
          "trigger": "结局",
          "text": "无论结果如何，历史将铭记这一刻。",
          "options": []
        }
      ]
    },
