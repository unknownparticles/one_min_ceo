  "npcs": [
    {
      "id": "npc_advisor",
      "name": "竞选顾问AI-7",
      "position": [
        1,
        3
      ],
      "dialogue": "欢迎，竞选人。还有60秒，银河的命运掌握在你手中。",
      "storyline": [
        {
          "stage": 1,
          "text": "顾问AI-7闪烁红光：'你的竞选宣言是什么？'",
          "options": [
            {
              "text": "我要统一银河贸易法",
              "nextStage": 2,
              "effect": "law"
            },
            {
              "text": "我要消灭所有外星官僚",
              "nextStage": 2,
              "effect": "war"
            }
          ]
        },
        {
          "stage": 2,
          "text": "顾问AI-7：'你的策略是？'",
          "options": [
            {
              "text": "用金钱收买",
              "nextStage": 3,
              "effect": "bribe"
            },
            {
              "text": "用武力威慑",
              "nextStage": 3,
              "effect": "force"
            }
          ]
        },
        {
          "stage": 3,
          "text": "顾问AI-7：'很好，但时间不多了。'",
          "options": [
            {
              "text": "开始最后冲刺",
              "nextStage": 4,
              "effect": "final"
            },
            {
              "text": "再思考一下",
              "nextStage": 4,
              "effect": "wait"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_rival",
      "name": "竞争对手CEO",
      "position": [
        3,
        7
      ],
      "dialogue": "你不可能赢的，我已经买通了所有议员！",
      "storyline": [
        {
          "stage": 1,
          "text": "竞争对手CEO冷笑：'你用什么来对抗我的资金？'",
          "options": [
            {
              "text": "我有创新技术",
              "nextStage": 2,
              "effect": "tech"
            },
            {
              "text": "我有民心",
              "nextStage": 2,
              "effect": "populace"
            }
          ]
        },
        {
          "stage": 2,
          "text": "竞争对手CEO：'那又怎样？我掌控媒体。'",
          "options": [
            {
              "text": "揭露他的丑闻",
              "nextStage": 3,
              "effect": "expose"
            },
            {
              "text": "与他合作",
              "nextStage": 3,
              "effect": "ally"
            }
          ]
        },
        {
          "stage": 3,
          "text": "竞争对手CEO：'你走投无路了！'",
          "options": [
            {
              "text": "启动紧急预案",
              "nextStage": 4,
              "effect": "emergency"
            },
            {
              "text": "放弃竞选",
              "nextStage": 4,
              "effect": "quit"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_voter",
      "name": "外星选民代表",
      "position": [
        5,
        5
      ],
      "dialogue": "我们厌倦了人类的统治！",
      "storyline": [
        {
          "stage": 1,
          "text": "外星选民代表：'你能给我们带来什么？'",
          "options": [
            {
              "text": "平等权利",
              "nextStage": 2,
              "effect": "equal"
            },
            {
              "text": "经济利益",
              "nextStage": 2,
              "effect": "money"
            }
          ]
        },
        {
          "stage": 2,
          "text": "外星选民代表：'怎么保证？'",
          "options": [
            {
              "text": "签署星际公约",
              "nextStage": 3,
              "effect": "treaty"
            },
            {
              "text": "提供能源援助",
              "nextStage": 3,
              "effect": "energy"
            }
          ]
        },
        {
          "stage": 3,
          "text": "外星选民代表：'好吧，我们拭目以待。'",
          "options": [
            {
              "text": "表示感谢",
              "nextStage": 4,
              "effect": "thanks"
            },
            {
              "text": "继续拉票",
              "nextStage": 4,
              "effect": "campaign"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_assistant",
      "name": "私人秘书",
      "position": [
        8,
        2
      ],
      "dialogue": "老板，还有30秒，请做最后准备。",
      "storyline": [
        {
          "stage": 1,
          "text": "秘书慌张地说：'我们漏掉了关键选区的数据！'",
          "options": [
            {
              "text": "临场发挥",
              "nextStage": 2,
              "effect": "improv"
            },
            {
              "text": "用备用数据",
              "nextStage": 2,
              "effect": "backup"
            }
          ]
        },
        {
          "stage": 2,
          "text": "秘书：'还有一个坏消息，对手在散布谣言。'",
          "options": [
            {
              "text": "立刻辟谣",
              "nextStage": 3,
              "effect": "deny"
            },
            {
              "text": "忽略它",
              "nextStage": 3,
              "effect": "ignore"
            }
          ]
        },
        {
          "stage": 3,
          "text": "秘书：'时间只剩10秒了！'",
          "options": [
            {
              "text": "深呼吸上台",
              "nextStage": 4,
              "effect": "calm"
            },
            {
              "text": "冲上台",
              "nextStage": 4,
              "effect": "rush"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_guard",
      "name": "皇家卫兵",
      "position": [
        10,
        10
      ],
      "dialogue": "皇帝陛下即将驾到，请退后。",
      "storyline": [
        {
          "stage": 1,
          "text": "卫兵：'请出示你的竞选许可。'",
          "options": [
            {
              "text": "出示电子许可",
              "nextStage": 2,
              "effect": "show"
            },
            {
              "text": "试图贿赂",
              "nextStage": 2,
              "effect": "bribe"
            }
          ]
        },
        {
          "stage": 2,
          "text": "卫兵：'许可有效。但皇帝要求你回答一个问题。'",
          "options": [
            {
              "text": "准备回答",
              "nextStage": 3,
              "effect": "ready"
            },
            {
              "text": "请求提示",
              "nextStage": 3,
              "effect": "hint"
            }
          ]
        },
        {
          "stage": 3,
          "text": "卫兵：'问题：你为何想当皇帝？'",
          "options": [
            {
              "text": "为了服务众生",
              "nextStage": 4,
              "effect": "serve"
            },
            {
              "text": "为了权力",
              "nextStage": 4,
              "effect": "power"
            }
          ]
        }
      ]
    }
