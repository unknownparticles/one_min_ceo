    {
      "id": 1,
      "name": "典狱长",
      "dialog": "董事长！主电源将在60秒后中断！",
      "position": {
        "x": 1,
        "y": 1
      },
      "storyline": [
        {
          "stage": 1,
          "dialog": "紧急情况！主电源即将断电，所有系统将瘫痪！",
