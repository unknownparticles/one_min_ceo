  "npcs": [
    {
      "id": "npc_01",
      "name": "时空审计官",
      "position": [
        1,
        2
      ],
      "storyline": [
        {
          "stage": 1,
          "trigger": "首次对话",
          "dialog": "时空快递的账目出现了38世纪未入账的快递费！你得在60秒内解决。",
          "options": [
            {
              "text": "用时间回溯修正账目",
              "effect": "time_fix"
            },
            {
              "text": "直接贿赂审计官",
              "effect": "bribe_auditor"
            }
          ]
        },
        {
          "stage": 2,
          "trigger": "stage1后",
          "dialog": "情况更糟了，星际税务局也介入了！",
          "options": [
            {
              "text": "启动紧急平行宇宙转移",
              "effect": "parallel_escape"
            },
            {
              "text": "召开临时股东大会",
              "effect": "shareholder_meeting"
            }
          ]
        },
        {
          "stage": 3,
          "trigger": "stage2后",
          "dialog": "最后一分钟，你必须决定是否泄露时间旅行技术以换取上市批准。",
          "options": [
            {
              "text": "泄露技术",
              "effect": "leak_tech"
            },
            {
              "text": "拒绝并坚持合规",
              "effect": "refuse_leak"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_02",
      "name": "未来投资人",
      "position": [
        4,
        5
      ],
      "storyline": [
        {
          "stage": 1,
          "trigger": "互动",
          "dialog": "我是来自2157年的投资人，你的快递公司前景如何？",
          "options": [
            {
              "text": "展示增长率",
              "effect": "show_growth"
            },
            {
              "text": "承诺未来分红",
              "effect": "promise_dividend"
            }
          ]
        },
        {
          "stage": 2,
          "trigger": "stage1后",
          "dialog": "我注意到你们的时空穿梭器有安全隐患。",
          "options": [
            {
              "text": "否认问题",
              "effect": "deny_issue"
            },
            {
              "text": "承认并承诺改进",
              "effect": "admit_and_fix"
            }
          ]
        },
        {
          "stage": 3,
          "trigger": "stage2后",
          "dialog": "要么你让我参与董事会，要么我撤资。",
          "options": [
            {
              "text": "同意加入董事会",
              "effect": "board_seat"
            },
            {
              "text": "拒绝并寻找新投资人",
              "effect": "find_new_investor"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_03",
      "name": "竞争对手CEO",
      "position": [
        7,
        10
      ],
      "storyline": [
        {
          "stage": 1,
          "trigger": "接近",
          "dialog": "哈哈，你的公司就要完蛋了！",
          "options": [
            {
              "text": "冷静回应",
              "effect": "calm_response"
            },
            {
              "text": "嘲讽回去",
              "effect": "mock_back"
            }
          ]
        },
        {
          "stage": 2,
          "trigger": "stage1后",
          "dialog": "我已经买通了你的几个董事。",
          "options": [
            {
              "text": "调查内鬼",
              "effect": "investigate_traitor"
            },
            {
              "text": "直接开董事会整顿",
              "effect": "board_overhaul"
            }
          ]
        },
        {
          "stage": 3,
          "trigger": "stage2后",
          "dialog": "最后通牒：放弃上市，或者我揭露你的丑闻。",
          "options": [
            {
              "text": "妥协放弃",
              "effect": "give_up_ipo"
            },
            {
              "text": "反击揭露他的秘密",
              "effect": "counter_expose"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_04",
      "name": "首席工程师",
      "position": [
        3,
        5
      ],
      "storyline": [
        {
          "stage": 1,
          "trigger": "对话",
          "dialog": "老板，时空引擎超载了！我们可能被传送到恐龙时代。",
          "options": [
            {
              "text": "要求立即检修",
              "effect": "urgent_repair"
            },
            {
              "text": "忽略风险继续运行",
              "effect": "ignore_risk"
            }
          ]
        },
        {
          "stage": 2,
          "trigger": "stage1后",
          "dialog": "找到问题了：一个37世纪的零件坏了，但库存是空的。",
          "options": [
            {
              "text": "从平行宇宙偷一个",
              "effect": "steal_part"
            },
            {
              "text": "自己研发替代品",
              "effect": "r_d_replacement"
            }
          ]
        },
        {
          "stage": 3,
          "trigger": "stage2后",
          "dialog": "如果我们让引擎超负荷，可能会创造时间悖论。",
          "options": [
            {
              "text": "冒险超负荷",
              "effect": "overload_engine"
            },
            {
              "text": "关闭系统保守安全",
              "effect": "shutdown_safely"
            }
          ]
        }
      ]
    },
    {
      "id": "npc_05",
      "name": "星际媒体记者",
      "position": [
        10,
        8
      ],
      "storyline": [
        {
          "stage": 1,
          "trigger": "采访",
          "dialog": "请问贵公司的快递员是否有时间旅行职业病？",
          "options": [
            {
              "text": "否认并转移话题",
              "effect": "deny_and_shift"
            },
            {
              "text": "承认并说明已采取措施",
              "effect": "admit_and_measures"
            }
          ]
        },
        {
          "stage": 2,
          "trigger": "stage1后",
          "dialog": "有人爆料你们使用奴隶劳工。",
          "options": [
            {
              "text": "否认并声称是竞争对手污蔑",
              "effect": "deny_and_blame"
            },
            {
              "text": "承诺调查并公开",
              "effect": "promise_investigation"
            }
          ]
        },
        {
          "stage": 3,
          "trigger": "stage2后",
          "dialog": "上市前，你会发布官方声明吗？",
          "options": [
            {
              "text": "发布积极声明",
              "effect": "positive_statement"
            },
            {
              "text": "保持沉默",
              "effect": "keep_silent"
            }
          ]
        }
      ]
    }
  ],
